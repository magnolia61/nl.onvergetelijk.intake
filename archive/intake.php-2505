        wachthond($extdebug,4, "new_vogaanvraag_actstatus", $new_vogaanvraag_actstatus);
        wachthond($extdebug,4, "new_vogaanvraag_actprio",   $new_vogaanvraag_actprio);
        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE [PRE] 6.4 BEPAAL NEW STATUS ACTIVITEIT VOG ONTVANGST");
        wachthond($extdebug,2, "########################################################################");

        $intake_status_vogontvangst_array  = intake_status_vogontvangst($contact_id, $array_allpart_ditjaar, $event_array, $intake_array, $groupID);
        wachthond($extdebug,2, "intake_status_vogontvangst_array",   $intake_status_vogontvangst_array);

        $new_cont_vogstatus         = $intake_status_vogontvangst_array['new_cont_vogstatus'];
        $new_part_vogstatus         = $intake_status_vogontvangst_array['new_part_vogstatus'];
        $new_vogontvangst_actdatum  = $intake_status_vogontvangst_array['new_vogontvangst_actdatum'];        
        $new_vogontvangst_actstatus = $intake_status_vogontvangst_array['new_vogontvangst_actstatus'];
        $new_vogontvangst_actprio   = $intake_status_vogontvangst_array['new_vogontvangst_actprio'];

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,4, "new_cont_vogstatus",        $new_cont_vogstatus);
        wachthond($extdebug,4, "new_part_vogstatus",        $new_part_vogstatus);
        wachthond($extdebug,4, "new_vogontvangst_actdatum", $new_vogontvangst_actdatum);
        wachthond($extdebug,4, "new_vogontvangst_actstatus",$new_vogontvangst_actstatus);
        wachthond($extdebug,4, "new_vogontvangst_actprio",  $new_vogontvangst_actprio);
        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE [PRE] 6.3 VOG - INJECTEER WAARDE IN PARAMS",           "[VOG]");
        wachthond($extdebug,2, "########################################################################");

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE [PRE] 6.4 VOG - GET & UPDATE ACTIVITIES",              "[VOG]");
        wachthond($extdebug,2, "########################################################################");

//      wachthond($extdebug,4, "event_array",               $event_array);
//      $event_fiscalyear = $event_array['event_fiscalyear']             ?? NULL;
        wachthond($extdebug,3, "event_fiscalyear",          $event_fiscalyear);

        $activity_array = array(
            'displayname'       => $displayname,
            'contact_id'        => $contact_id,
            'activity_source'   => 1, 
            'activity_target'   => $contact_id,
        );

        $intake_array = array(
            'vog_status'        => $new_cont_vogstatus,
            'vog_laatste'       => $new_cont_voglaatste,
            'vog_nodig'         => $new_cont_vognodig,
            'vog_verzoek'       => $new_cont_vogverzoek,
            'vog_reminder'      => $new_cont_vogreminder,
            'vog_aanvraag'      => $new_cont_vogaanvraag,
            'vog_datum'         => $new_cont_vogdatum,
        );

        #########################################################################
        ### GET & UPDATE ACTIVITY                                  [VOG VERZOEK]
        #########################################################################

        if ($new_vogverzoek_actstatus) {

            $activity_array['activity_type_id']         = 118;              // vog_verzoek
            $activity_array['activity_type_naam']       = 'vog_verzoek';    // 118  [required]
            $activity_intake_array  = intake_activity_get($contact_id, $activity_array, $event_fiscalyear);
            wachthond($extdebug,2, "activity_intake_array", $activity_intake_array);
            $vogverzoek_activity_id = $activity_intake_array['activity_id'] ?? NULL;

            wachthond($extdebug,4, 'intake_array',                      $intake_array);
            wachthond($extdebug,4, 'verzoek activity_array',            $activity_array);
            wachthond($extdebug,4, 'new_vogverzoek_actstatus',          $new_vogverzoek_actstatus);

            if ($vogverzoek_activity_id AND $new_vogverzoek_actstatus) {
                $activity_array['activity_id']          = $vogverzoek_activity_id;
                $activity_array['activity_date_time']   = $new_vogverzoek_actdatum;
                $activity_array['activity_status_name'] = $new_vogverzoek_actstatus;
                $activity_array['activity_prioriteit']  = $new_vogverzoek_actprio;
                $intake_activity_update = intake_activity_update($contact_id, $activity_array, $event_array, $intake_array, $groupID);
                wachthond($extdebug,3, "intake_activity_update", "[NEW ACTID: $intake_activity_update]");
            }
        }

        #########################################################################
        ### GET & UPDATE ACTIVITY                                  [VOG AANVRAAG]
        #########################################################################

        if ($new_vogaanvraag_actstatus) {

            $activity_array['activity_type_id']         = 119;              // vog_aanvraag
            $activity_array['activity_type_naam']       = 'vog_aanvraag';   // 119  [required]
            $activity_intake_array  = intake_activity_get($contact_id, $activity_array, $event_fiscalyear);
            wachthond($extdebug,2, "activity_intake_array", $activity_intake_array);
            $vogaanvraag_activity_id = $activity_intake_array['activity_id'] ?? NULL;

            wachthond($extdebug,4, 'intake_array',                      $intake_array);
            wachthond($extdebug,4, 'aanvraag activity_array',           $activity_array);
            wachthond($extdebug,4, 'new_vogaanvraag_actstatus',         $new_vogaanvraag_actstatus);

            if ($vogaanvraag_activity_id AND $new_vogaanvraag_actstatus) {
                $activity_array['activity_id']          = $vogaanvraag_activity_id;
                $activity_array['activity_date_time']   = $new_vogaanvraag_actdatum;
                $activity_array['activity_status_name'] = $new_vogaanvraag_actstatus;
                $activity_array['activity_prioriteit']  = $new_vogaanvraag_actprio;                
                $intake_activity_update = intake_activity_update($contact_id, $activity_array, $event_array, $intake_array, $groupID);
                wachthond($extdebug,3, "intake_activity_update", "[NEW ACTID: $intake_activity_update]");
            }
        }

        #########################################################################
        ### GET & UPDATE ACTIVITY                                 [VOG ONTVANGST]
        #########################################################################

        if ($new_vogontvangst_actstatus) {

            $activity_array['activity_type_id']         = 120;              // vog_ontvangst
            $activity_array['activity_type_naam']       = 'vog_ontvangst';  // 120  [required]
            $activity_intake_array  = intake_activity_get($contact_id, $activity_array, $event_fiscalyear);
            wachthond($extdebug,2, "activity_intake_array", $activity_intake_array);
            $vogontvangst_activity_id = $activity_intake_array['activity_id'] ?? NULL;

            wachthond($extdebug,4, 'intake_array',                      $intake_array);
            wachthond($extdebug,4, 'ontvangst activity_array',          $activity_array);
            wachthond($extdebug,4, 'new_vogontvangst_actstatus',        $new_vogontvangst_actstatus);

            if ($vogontvangst_activity_id AND $new_vogontvangst_actstatus) {
                $activity_array['activity_id']          = $vogontvangst_activity_id;
                $activity_array['activity_date_time']   = $new_vogontvangst_actdatum;
                $activity_array['activity_status_name'] = $new_vogontvangst_actstatus;
                $activity_array['activity_prioriteit']  = $new_vogontvangst_actprio;                
                $intake_activity_update = intake_activity_update($contact_id, $activity_array, $event_array, $intake_array, $groupID);
                wachthond($extdebug,3, "intake_activity_update", "[NEW ACTID: $intake_activity_update]");
            }
        }

        ##########################################################################################
        ### INJECTEER WAARDE IN PARAMS INDIEN WAARDE AANWEZIG
        ##########################################################################################

        wachthond($extdebug,4,  "key_vog_nodig",           $key_vog_nodig);

        if (is_numeric($key_vog_nodig) AND !empty($new_cont_vognodig)) {
            wachthond($extdebug,3, 'OLD params[key_vog_nodig][value]', $params[$key_vog_nodig]);
            $params[$key_vog_nodig]['value'] = $new_cont_vognodig;
            wachthond($extdebug,3, 'NEW params[key_vog_nodig][value]', $params[$key_vog_nodig]);
        }

        wachthond($extdebug,4,  "key_vog_status",           $key_vog_status);
        wachthond($extdebug,4,  "new_cont_vogstatus",       $new_cont_vogstatus);

        if (is_numeric($key_vog_status) AND !empty($new_cont_vogstatus)) {
            wachthond($extdebug,3, 'OLD params[key_vog_status][value]', $params[$key_vog_status]);
            $params[$key_vog_status]['value'] = $new_cont_vogstatus;
            wachthond($extdebug,3, 'NEW params[key_vog_status][value]', $params[$key_vog_status]);
        }

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE [PRE] 5.0 REF - CONSOLIDATE DATA",            "[$displayname]");
        wachthond($extdebug,2, "########################################################################");

        $extdebug = $extdebug_cont_ref;

        wachthond($extdebug,3, 'val_ref_persoon',           $val_ref_persoon);
        wachthond($extdebug,3, 'val_ref_laatste',           $val_ref_laatste);
        wachthond($extdebug,1, 'new_cont_refnodig',         $new_cont_refnodig);
        wachthond($extdebug,1, 'new_cont_refstatus',        $new_cont_refstatus);

        if ($val_ref_laatste) {

            $refrecent_infiscalyear_ditjaar     = infiscalyear($val_ref_laatste,        $today_datetime,  'refrecent','ditjaar');
            $refrecent_binnengrens              = date_biggerequal($val_ref_laatste,    $grensrefnoggoed, 'refrecent','grensref');
            $refrecent_buitengrens              = date_biggerequal($grensrefnoggoed,    $val_ref_laatste, 'grensref', 'refrecent');

            wachthond($extdebug,3, "refrecent_infiscalyear_ditjaar",    "$refrecent_infiscalyear_ditjaar\t[refrecent: $val_ref_laatste]");
            wachthond($extdebug,3, "refrecent_binnengrens",             "$refrecent_binnengrens\t[refrecent: $val_ref_laatste]");
            wachthond($extdebug,3, "refrecent_buitengrens",             "$refrecent_buitengrens\t[refrecent: $val_ref_laatste]");
        }

        if ($val_ref_persoon) {

            $refpersoon_infiscalyear_ditjaar    = infiscalyear($val_ref_persoon,        $today_datetime,  'refpersoon','ditjaar');
            $refpersoon_binnengrens             = date_biggerequal($val_ref_persoon,    $grensrefnoggoed, 'refpersoon','grensref');
            $refpersoon_buitengrens             = date_biggerequal($grensrefnoggoed,    $val_ref_persoon, 'grensref', 'refpersoon');

            wachthond($extdebug,3, "refpersoon_infiscalyear_ditjaar",    "$refpersoon_infiscalyear_ditjaar\t[refpersoon: $val_ref_persoon]");
            wachthond($extdebug,3, "refpersoon_binnengrens",             "$refpersoon_binnengrens\t[refpersoon: $val_ref_persoon]");
            wachthond($extdebug,3, "refpersoon_buitengrens",             "$refpersoon_buitengrens\t[refpersoon: $val_ref_persoon]");
        }

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE [PRE] 5.1 REF - BEPAAL WAARDE NODIG",                  "[REF]");
        wachthond($extdebug,2, "########################################################################");

        ### INDIEN ER GEEN REFRECENT IS DAN IS DEZE DUS NOG NODIG
        if ($curcv_keer_leid == 1) {
            $new_cont_refnodig   = 'eerstex';
        } elseif ($curcv_keer_leid >= 2) { 
            $new_cont_refnodig   = 'opnieuw';
        }

        if (in_array($part_functie, array('hoofdleiding', 'bestuurslid'))) {
            $new_cont_refnodig   = 'elkjaar';
        }

        // REFRECENT VALT BINNEN GRENS NOGGOED
        if ($refrecent_binnengrens == 1) {
            $new_cont_refnodig   = 'noggoed';
        }

        wachthond($extdebug,3,  "new_cont_refnodig",    $new_cont_refnodig);

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE [PRE] 5.2 REF - BEPAAL WAARDE STATUS",          "$displayname");
        wachthond($extdebug,2, "########################################################################");

        $new_cont_refstatus      = 'onbekend'; // basisstatus

        if ($val_ref_laatste) {

            wachthond($extdebug,3, "########################################################################");
            wachthond($extdebug,1, "### A STATUS REF IGV REFRECENT BUITEN GRENSNOGGOED",              "[REF]");
            wachthond($extdebug,3, "########################################################################");

            // REFRECENT VALT BUITEN GRENS NOGGOED
            if ($refrecent_buitengrens == 1 OR empty($val_ref_laatste)) {
                wachthond($extdebug,2,  "DATUM REF [$val_ref_laatste] VALT BUITEN GRENS NOGGOED REF ($grensnoggoedjaar JAAR)",
                                        "[>$grensrefnoggoed]");
                $new_cont_refstatus      = 'onbekend';
            }

            wachthond($extdebug,3, "########################################################################");
            wachthond($extdebug,1, "### B STATUS REF IGV REFRECENT BINNEN GRENSNOGGOED",              "[REF]");
            wachthond($extdebug,3, "########################################################################");

            // REFRECENT VALT BINNEN GRENS NOGGOED
            if ($refrecent_binnengrens == 1) {
                wachthond($extdebug,2,  "DATUM REF [$val_ref_laatste] VALT BINNEN GRENS NOGGOED REF ($grensnoggoedjaar JAAR)",
                                        "[>$grensrefnoggoed]");
                $new_cont_refstatus     = 'noggoed';
            }

            wachthond($extdebug,3, "########################################################################");
            wachthond($extdebug,1, "### E STATUS REF IGV REFFEEDBACK DIT JAAR ONTVANGEN",             "[REF]");
            wachthond($extdebug,3, "########################################################################");

            if ($refrecent_infiscalyear_ditjaar == 1) {

                wachthond($extdebug,2,  "DATUM REFFEEDBACK [$val_ref_laatste] VALT BINNEN HUIDIGE FISCALE JAAR)",
                                        "[>$today_fiscalyear_start]");
                $new_cont_refstatus = 'ontvangen';
            }

        } else {

            wachthond($extdebug,3, "########################################################################");
            wachthond($extdebug,1, "### C STATUS REF IGV REFRECENT = LEEG",                           "[REF]");
            wachthond($extdebug,3, "########################################################################");

            ### INDIEN ER GEEN REFRECENT IS DAN IS DEZE DUS NOG NODIG
            if ($curcv_keer_leid == 1) {
                $new_cont_refnodig   = 'eerstex';
            } elseif ($curcv_keer_leid >= 2) { 
                $new_cont_refnodig   = 'opnieuw';
            }

            wachthond($extdebug,2, "DATUM REFRECENT IS LEEG DUS REFNODIG WORDT", "[$new_cont_refnodig]");            
        }

        wachthond($extdebug,3, "########################################################################");
        wachthond($extdebug,1, "### D STATUS REF IGV REFPERSOON IN DIT FISCALYEAR",               "[REF]");
        wachthond($extdebug,3, "########################################################################");

        if ($refpersoon_binnengrens == 1 AND $refrecent_infiscalyear_ditjaar != 1) {
            wachthond($extdebug,2,  "DATUM REFPERSOON [$val_ref_persoon] VALT BINNEN HUIDIGE FISCALE JAAR)",
                                    "[>$today_fiscalyear_start]");
            $new_cont_refstatus  = 'vragen';              
        }

        wachthond($extdebug,3,  "new_cont_refstatus",       $new_cont_refstatus);

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE [PRE] 5.3 REF - INJECTEER WAARDE IN PARAMS",           "[REF]");
        wachthond($extdebug,2, "########################################################################");

        wachthond($extdebug,4,  "key_ref_nodig",           $key_ref_nodig);

        if (is_numeric($key_ref_nodig) AND !empty($new_cont_refnodig)) {
            wachthond($extdebug,3, 'OLD params[key_ref_nodig][value]', $params[$key_ref_nodig]);
            $params[$key_ref_nodig]['value'] = $new_cont_refnodig;
            wachthond($extdebug,3, 'NEW params[key_ref_nodig][value]', $params[$key_ref_nodig]);
        }

        wachthond($extdebug,4,  "key_ref_status",           $key_ref_status);

        if (is_numeric($key_ref_status) AND !empty($new_cont_refstatus)) {
            wachthond($extdebug,3, 'OLD params[key_ref_status][value]', $params[$key_ref_status]);
            $params[$key_ref_status]['value'] = $new_cont_refstatus;
            wachthond($extdebug,3, 'NEW params[key_ref_status][value]', $params[$key_ref_status]);
        }

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE [PRE] 7.1 INT - BEPAAL WAARDE NODIG",                  "[INT]");
        wachthond($extdebug,2, "########################################################################");

        $extdebug = $extdebug_intake_cont;

        ### INDIEN ER GEEN REFRECENT IS DAN IS DEZE DUS NOG NODIG
        if ($curcv_keer_leid == 1) {
            $new_cont_intnodig   = 'eerstex';
        } elseif ($curcv_keer_leid >= 2) { 
            $new_cont_intnodig   = 'opnieuw';
        }

        if (in_array($part_functie, array('hoofdleiding', 'bestuurslid'))) {
            $new_cont_intnodig   = 'elkjaar';
        }

        wachthond($extdebug,3,  "new_cont_intnodig",    $new_cont_intnodig);

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE [PRE] 7.2 INT - BEPAAL STATUS",                        "[INT]");
        wachthond($extdebug,2, "########################################################################");

        if (in_array($new_cont_nawstatus, array("noggoed", "bijgewerkt")))           {
            $intakestatusnawdone  = 1;
        }
        if (in_array($new_cont_biostatus, array("noggoed", "bijgewerkt")))           {
            $intakestatusbiodone  = 1;
        }
        if (in_array($new_cont_refstatus,    array("noggoed", "vragen", "ontvangen")))  {   // M61: wat te doen met status: bekend
            $intakestatusrefdone  = 1;
        }
        if (in_array($new_cont_vogstatus,    array("noggoed", "ontvangen")))            {   // M61: wat te doen met status: ingediend
            $intakestatusvogdone  = 1;
        }

        if ($intakestatusnawdone == 1 AND $intakestatusbiodone == 1 AND $intakestatusrefdone == 1 AND $intakestatusvogdone == 1) { 
            $new_cont_intstatus = 'compleet';
        } else {
            $new_cont_intstatus = 'gedeeltelijk';            
        }

        wachthond($extdebug,4,  "new_cont_intstatus",       $new_cont_intstatus);

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE [PRE] 7.3 INT - INJECTEER WAARDE IN PARAMS",           "[INT]");
        wachthond($extdebug,2, "########################################################################");

        wachthond($extdebug,3,  "key_int_nodig",            $key_int_nodig);

        if (is_numeric($key_int_nodig) AND !empty($new_cont_intnodig)) {
            wachthond($extdebug,3, 'OLD params[key_int_nodig][value]', $params[$key_int_nodig]);
            $params[$key_int_nodig]['value'] = $new_cont_intnodig;
            wachthond($extdebug,3, 'NEW params[key_int_nodig][value]', $params[$key_int_nodig]);
        }

        wachthond($extdebug,4,  "key_int_status",           $key_int_status);

        if (is_numeric($key_int_status) AND !empty($new_cont_intstatus)) {
            wachthond($extdebug,3, 'OLD params[key_int_status][value]', $params[$key_int_status]);
            $params[$key_int_status]['value'] = $new_cont_intstatus;
            wachthond($extdebug,3, 'NEW params[key_int_status][value]', $params[$key_int_status]);
        }

        wachthond($extdebug,2, 'today_kampjaar',            $today_kampjaar);
        wachthond($extdebug,1, 'new_cont_intnodig',         $new_cont_intnodig);
        wachthond($extdebug,1, 'new_cont_intstatus',        $new_cont_intstatus);

        wachthond($extdebug,4, "NEW params",                $params);

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE [PRE] 9.0 UPDATE PARTICIPANT DATA",                    "[INT]");
        wachthond($extdebug,2, "########################################################################");

        wachthond($extdebug,3, 'ditjaar_pos_leid_count',        $ditjaar_pos_leid_count);
        wachthond($extdebug,3, 'ditjaar_pos_leid_part_id',      $ditjaar_pos_leid_part_id);
        wachthond($extdebug,3, 'ditjaar_pos_leid_event_id',     $ditjaar_pos_leid_event_id);
        wachthond($extdebug,3, 'ditjaar_pos_leid_status_id',    $ditjaar_pos_leid_status_id);
        wachthond($extdebug,3, 'ditjaar_pos_leid_kampfunctie',  $ditjaar_pos_leid_kampfunctie);
        wachthond($extdebug,3, 'ditjaar_pos_leid_kampkort',     $ditjaar_pos_leid_kampkort);

        if ($ditjaar_pos_leid_count == 1 AND $ditjaar_pos_leid_part_id > 0) {

            $params_ditevent = [
                'checkPermissions'  => FALSE,
                'debug'             => $apidebug,
                'where' => [
                    ['id',  '=', $ditjaar_pos_leid_part_id],
                ],
                'values' => [
                    'id'    =>   $ditjaar_pos_leid_part_id,
                ],
            ];

            if ($new_cont_nawgecheckt)   { $params_ditevent['values']['PART.NAW_gecheckt']                  = $new_cont_nawgecheckt;}
            if ($new_cont_biogecheckt)   { $params_ditevent['values']['PART.BIO_gecheckt']                  = $new_cont_biogecheckt;}

            if ($new_cont_intnodig)      { $params_ditevent['values']['PART_LEID_INTERN.INT_nodig:name']    = $new_cont_intnodig;   }
            if ($new_cont_nawnodig)      { $params_ditevent['values']['PART_LEID_INTERN.NAW_nodig:name']    = $new_cont_nawnodig;   }
            if ($new_cont_bionodig)      { $params_ditevent['values']['PART_LEID_INTERN.BIO_nodig:name']    = $new_cont_bionodig;   }
            if ($new_cont_refnodig)      { $params_ditevent['values']['PART_LEID_INTERN.REF_nodig:name']    = $new_cont_refnodig;   }
            if ($new_cont_vognodig)      { $params_ditevent['values']['PART_LEID_INTERN.VOG_nodig:name']    = $new_cont_vognodig;   }

            if ($new_cont_intstatus)     { $params_ditevent['values']['PART_LEID_INTERN.INT_status']        = $new_cont_intstatus;  }
            if ($new_cont_nawstatus)     { $params_ditevent['values']['PART_LEID_INTERN.NAW_status']        = $new_cont_nawstatus;  }
            if ($new_cont_biostatus)     { $params_ditevent['values']['PART_LEID_INTERN.BIO_status']        = $new_cont_biostatus;  }
            if ($new_cont_refstatus)     { $params_ditevent['values']['PART_LEID_INTERN.REF_status']        = $new_cont_refstatus;  }
            if ($new_cont_vogstatus)     { $params_ditevent['values']['PART_LEID_INTERN.VOG_status']        = $new_cont_vogstatus;  }

            wachthond($extdebug,3, "params_ditevent",                   $params_ditevent);
            $result_ditevent = civicrm_api4('Participant', 'update',    $params_ditevent);
            wachthond($extdebug,9, "result_ditevent",                   $result_ditevent);
        }

        wachthond($extdebug,1, "########################################################################");
        wachthond($extdebug,1, "### INTAKE [PRE] EINDE [$displayname $part_functie $part_kampkort]", "[groupID: $groupID / op: $op]");
        wachthond($extdebug,1, "########################################################################");

    }

    #########################################################################
    ### INTAKE CONT [PRE]                                             [START]
    #########################################################################

    #########################################################################
    ### INTAKE PART REF [PRE]                                         [START]
    #########################################################################

    if (in_array($groupID, $profilepartref))  {

        $extdebug = $extdebug_part_ref;

        wachthond($extdebug,1, "########################################################################");
        wachthond($extdebug,1, "### INTAKE PART REF [PRE] 1.1 GET VALUES FROM PARAMS", "[$displayname - groupID: $groupID]");
        wachthond($extdebug,1, "########################################################################");

        wachthond($extdebug,4, "entityid",          $entityID);
        wachthond($extdebug,4, "params (size)",     $arraysize);

        foreach($params as $i=>$item) {

            if ( !isset($indexed[$i][$item['id']]) ) {
                $indexed[$i]['key']         = $i;
//              $indexed[$i]['entity_id']   = $item['entity_id']    ?? NULL;
                $indexed[$i]['column_name'] = $item['column_name']  ?? NULL;
//              $indexed[$i]['table_name']  = $item['table_name']   ?? NULL;
                $indexed[$i]['value']       = $item['value']        ?? NULL;
            }

            if (!isset($key_datum_refpersoon[$i])  AND $item['column_name'] == "ref_persoon_1301"  ) {   $all_datum_refpersoon[]    = $i;}
            if (!isset($key_datum_refgevraagd[$i]) AND $item['column_name'] == "ref_gevraagd_1295" ) {   $all_datum_refgevraagd[]   = $i;}
            if (!isset($key_datum_reffeedback[$i]) AND $item['column_name'] == "ref_feedback_1296" ) {   $all_datum_reffeedback[]   = $i;}
        }

        wachthond($extdebug,4, "indexed", $indexed);

        $key_datum_refpersoon   = $all_datum_refpersoon[0];
        $key_datum_refgevraagd  = $all_datum_refgevraagd[0];
        $key_datum_reffeedback  = $all_datum_reffeedback[0];

        wachthond($extdebug,3, "key_datum_refpersoon",      $key_datum_refpersoon);
        wachthond($extdebug,3, "key_datum_refgevraagd",     $key_datum_refgevraagd);
        wachthond($extdebug,3, "key_datum_reffeedback",     $key_datum_reffeedback);

        ##########################################################################################
        ### GET DATUM REF VERZOEK
        ##########################################################################################        

        if ($key_datum_refpersoon >= 0) {
            $raw_datum_refpersoon  = $params[$key_datum_refpersoon]['value']        ?? NULL;
            if ($raw_datum_refpersoon) {
                $val_datum_refpersoon    = date("Y-m-d H:i:s", strtotime($raw_datum_refpersoon)); 
            } else {
                $val_datum_refpersoon    = NULL; 
            }
            wachthond($extdebug,2, "val_datum_refpersoon", $val_datum_refpersoon);
        }

        ##########################################################################################
        ### GET DATUM REF AANVRAAG
        ##########################################################################################        

        if ($key_datum_refgevraagd >= 0) {
            $raw_datum_refgevraagd  = $params[$key_datum_refgevraagd]['value']        ?? NULL;
            if ($raw_datum_refgevraagd) {
                $val_datum_refgevraagd    = date("Y-m-d H:i:s", strtotime($raw_datum_refgevraagd)); 
            } else {
                $val_datum_refgevraagd    = NULL; 
            }
            wachthond($extdebug,2, "val_datum_refgevraagd", $val_datum_refgevraagd);
        }

        ##########################################################################################
        ### GET DATUM REF NIEUW
        ##########################################################################################        

        if ($key_datum_reffeedback >= 0) {
            $raw_datum_reffeedback  = $params[$key_datum_reffeedback]['value']        ?? NULL;
            if ($raw_datum_reffeedback) {
                $val_datum_reffeedback    = date("Y-m-d H:i:s", strtotime($raw_datum_reffeedback)); 
            } else {
                $val_datum_reffeedback    = NULL; 
            }
            wachthond($extdebug,2, "val_datum_reffeedback", $val_datum_reffeedback);
        }

        ##########################################################################################
        ### GET DISPLAYNAME
        ##########################################################################################        

        if ($entityID > 0) {

            $params_part = [
                'select' => [
                    'id',
                    'contact_id',
                    'contact_id.display_name',
                    'contact_id.INTAKE.REF_laatste',     
                    'PART.PART_kampstart',
                    'PART.PART_kampkort',
                    'PART.PART_kampfunctie',
                    'PART_LEID_INTERN.REF_nodig',
                    'PART_LEID_INTERN.REF_status',
                    'PART_LEID_REF.REF_persoon',
                    'PART_LEID_REF.REF_gevraagd',
                    'PART_LEID_REF.REF_feedback',
                    'PART_LEID_REFERENTIE.referentie_cid',
                    'PART_LEID_REFERENTIE.referentie_naam',
                ],
                'where' => [
                    ['is_test',         'IN', [TRUE, FALSE]], 
                    ['id',              '=',  $entityID],
                ],
                'checkPermissions' => FALSE,
                'debug' => $apidebug,
            ];
        }
        wachthond($extdebug,3, 'params_part',           $params_part);
        $result_part = civicrm_api4('Participant','get',$params_part);
        wachthond($extdebug,9, 'result_part',           $result_part);

        if (isset($result_part))    {
            $part_id            = $result_part[0]['id']                                     ?? NULL;
            $contact_id         = $result_part[0]['contact_id']                             ?? NULL;
            $displayname        = $result_part[0]['contact_id.display_name']                ?? NULL;
            $kampstart          = $result_part[0]['PART.PART_kampstart']                    ?? NULL;
            $kampkort           = $result_part[0]['PART.PART_kampkort']                     ?? NULL;
            $kampfunctie        = $result_part[0]['PART.PART_kampfunctie']                  ?? NULL;

            $part_refdatum      = $result_part[0]['contact_id.INTAKE.REF_datum']            ?? NULL;
            $part_refnodig      = $result_part[0]['PART_LEID_INTERN.REF_nodig']             ?? NULL;
            $part_refstatus     = $result_part[0]['PART_LEID_INTERN.REF_status']            ?? NULL;
            $part_refpersoon    = $result_part[0]['PART_LEID_REF.REF_persoon']              ?? NULL;
            $part_refgevraagd   = $result_part[0]['PART_LEID_REF.REF_gevraagd']             ?? NULL;
            $part_reffeedback   = $result_part[0]['PART_LEID_REF.REF_feedback']             ?? NULL;

            $part_refcid        = $result_part[0]['PART_LEID_REFERENTIE.referentie_cid']    ?? NULL;
            $part_refnaam       = $result_part[0]['PART_LEID_REFERENTIE.referentie_naam']   ?? NULL;

            wachthond($extdebug,1, 'contact_id',        $contact_id);
            wachthond($extdebug,1, 'displayname',       $displayname);
            wachthond($extdebug,1, 'kampstart',         $kampstart);
            wachthond($extdebug,1, 'kampkort',          $kampkort);
            wachthond($extdebug,1, 'kampfunctie',       $kampfunctie);

            wachthond($extdebug,1, 'part_refdatum',     $part_refdatum);
            wachthond($extdebug,1, 'part_refnodig',     $part_refnodig);
            wachthond($extdebug,1, 'part_refstatus',    $part_refstatus);
            wachthond($extdebug,1, 'part_refpersoon',   $part_refpersoon);
            wachthond($extdebug,1, 'part_refgevraagd',  $part_refgevraagd);
            wachthond($extdebug,1, 'part_reffeedback',  $part_reffeedback);

            wachthond($extdebug,1, 'part_refcid',       $part_refcid);
            wachthond($extdebug,1, 'part_refnaam',      $part_refnaam);
        }

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE PART REF [PRE] 1.5 CONSOLIDATE DATA",         "[$displayname]");
        wachthond($extdebug,2, "########################################################################");

        wachthond($extdebug,2, "val_datum_refpersoon",  $val_datum_refpersoon);
        wachthond($extdebug,2, "val_datum_refgevraagd", $val_datum_refgevraagd);
        wachthond($extdebug,2, "val_datum_reffeedback", $val_datum_reffeedback);

        if (infiscalyear($val_datum_refpersoon, $kampstart) == 1) {    // INFISCALYEAR DITJAAR
            $new_cont_refcid        = $part_refcid;
            $new_cont_refnaam       = $part_refnaam;
            $new_cont_refpersoon    = $part_refpersoon;
            wachthond($extdebug,1, 'new_cont_refcid',       $new_cont_refcid);
            wachthond($extdebug,1, 'new_cont_refnaam',      $new_cont_refnaam);
            wachthond($extdebug,1, 'new_cont_refpersoon',   $new_cont_refpersoon);
        }

        if (infiscalyear($val_datum_refpersoon, $kampstart) == 1 OR infiscalyear($part_refpersoon, $kampstart) == 1) {

            wachthond($extdebug,2, "########################################################################");
            wachthond($extdebug,1, "### INTAKE PART REF [PRE] 1.5 REF PERSOON IN FISCALYEAR DITJAAR","[$displayname]");
            wachthond($extdebug,2, "########################################################################");

            $new_refpersoon_actstatus   = 'Completed';
            $new_part_refstatus         = 'vragen';
        }

        if (infiscalyear($val_datum_refgevraagd, $kampstart) == 1 OR infiscalyear($part_refgevraagd, $kampstart) == 1) {

            wachthond($extdebug,2, "########################################################################");
            wachthond($extdebug,1, "### INTAKE PART REF [PRE] 1.6 REF VERZOEK IN FISCALYEAR DITJAAR","[$displayname]");
            wachthond($extdebug,2, "########################################################################");

            $new_refverzoek_actstatus   = 'Pending';
            $new_part_refstatus         = 'gevraagd';
        }

        if (infiscalyear($val_datum_reffeedback, $kampstart) == 1 OR infiscalyear($part_reffeedback, $kampstart) == 1) {

            wachthond($extdebug,2, "########################################################################");
            wachthond($extdebug,1, "### INTAKE PART REF [PRE] 1.7 REF FEEDBACK IN FISCALYEAR DITJAAR","[$displayname]");
            wachthond($extdebug,2, "########################################################################");

            $new_refverzoek_actstatus   = 'Completed';
            $new_part_refstatus         = 'ontvangen';
        }

        ### SCHRIJF WAARDE PART NAAR CONT

        if (infiscalyear($val_datum_refpersoon,     $today_datetime) == 1) {    // INFISCALYEAR DITJAAR
            $new_cont_refstatus     = $new_part_refstatus ?? NULL;
        }
        if (infiscalyear($val_datum_refgevraagd,    $today_datetime) == 1) {    // INFISCALYEAR DITJAAR
            $new_cont_refstatus     = $new_part_refstatus ?? NULL;
        }
        if (infiscalyear($val_datum_reffeedback,    $today_datetime) == 1) {    // INFISCALYEAR DITJAAR
            $new_cont_refstatus     = $new_part_refstatus ?? NULL;
        }

        if (date_bigger($val_datum_refpersoon, $part_refpersoon)    OR empty($part_refpersoon))  {
            $new_cont_refpersoon   = $val_datum_refpersoon;
        }
        if (date_bigger($val_datum_refgevraagd, $part_refgevraagd)  OR empty($part_refgevraagd)) {
            $new_cont_refgevraagd   = $val_datum_refgevraagd;
        }
        if (date_bigger($val_datum_reffeedback, $part_refdatum)     OR empty($part_refdatum))    {
            $new_cont_refdatum      = $val_datum_reffeedback;
        }

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE PART REF [PRE] 2.0 GET REFERENTIE RELATION INFO", "[$displayname]");
        wachthond($extdebug,2, "########################################################################");

        $referentie_array = intake_referentie_get($contact_id, $groupID);
        wachthond($extdebug,3, "referentie_array",    $referentie_array);

        $referentie_relid       = $referentie_array['referentie_relid'];
        $referentie_start       = $referentie_array['referentie_start'];
        $referentie_einde       = $referentie_array['referentie_eindet'];
        $referentie_cid         = $referentie_array['ref_referentie_cid'];
        $referentie_naam        = $referentie_array['ref_referentie_naam'];
        $referentie_voornaam    = $referentie_array['ref_referentie_voornaam'];
        $referentie_geslacht    = $referentie_array['ref_referentie_geslacht'];
        $aanvrager_toestemming  = $referentie_array['ref_toestemming'];
        $aanvrager_relatie      = $referentie_array['ref_aanvrager_relatie'];
        $referentie_relatie     = $referentie_array['ref_referentie_relatie'];
        $referentie_gevraagd    = $referentie_array['ref_gevraagd'];
        $referentie_feedback    = $referentie_array['ref_feedback'];
        $referentie_bezwaar     = $referentie_array['ref_bezwaar'];
        $referentie_telefoon    = $referentie_array['ref_referentie_telefoon'];

        wachthond($extdebug,3, "referentie_relid",      $referentie_relid);
        wachthond($extdebug,3, "referentie_start",      $referentie_start);
        wachthond($extdebug,3, "referentie_einde",      $referentie_einde);
        wachthond($extdebug,3, "referentie_cid",        $referentie_cid);
        wachthond($extdebug,3, "referentie_naam",       $referentie_naam);
        wachthond($extdebug,3, "referentie_voornaam",   $referentie_voornaam);
        wachthond($extdebug,3, "referentie_geslacht",   $referentie_geslacht);
        wachthond($extdebug,3, "aanvrager_toestemming", $aanvrager_toestemming);
        wachthond($extdebug,3, "aanvrager_relatie",     $aanvrager_relatie);
        wachthond($extdebug,3, "referentie_relatie",    $referentie_relatie);
        wachthond($extdebug,3, "referentie_gevraagd",   $referentie_gevraagd);
        wachthond($extdebug,3, "referentie_feedback",   $referentie_feedback);
        wachthond($extdebug,3, "referentie_bezwaar",    $referentie_bezwaar);
        wachthond($extdebug,3, "referentie_telefoon",   $referentie_telefoon);

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE PART REF [PRE] 3.0 UPDATE INTAKE ACTIVITIES", "[$displayname]");
        wachthond($extdebug,2, "########################################################################");

//      $ditevent_fiscalyear = curriculum_civicrm_fiscalyear($kampstart);
//      wachthond($extdebug,4, 'ditevent_fiscalyear', $ditevent_fiscalyear);

        $activity_array = array(
            'displayname'               => $displayname,
            'contact_id'                => $contact_id,
            'activity_source'           => 1, 
            'activity_target'           => $contact_id,
        );

        $intake_array = array(
            'ref_nodig'                 => $part_refnodig,
            'ref_datum_persoon'         => $new_cont_refpersoon,
            'ref_datum_gevraagd'        => $new_cont_refgevraagd,
            'ref_datum_feedback'        => $new_cont_refdatum,
            'ref_bezwaar'               => $part_refbezwaar,
        );

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE PART REF [PRE] 3.1 GET & UPDATE ACTIVITY",      "[REFPERSOON]");
        wachthond($extdebug,2, "########################################################################");

        if ($new_refpersoon_actstatus) {

            // GET ACTIVITY
            $activity_array['activity_type_id']         = 139;              // ref_persoon
            $activity_array['activity_type_naam']       = 'ref_persoon';    // 139
            $activity_array['activity_subject']         = 'REF persoon doorgeven';
            $activity_intake_array  = intake_activity_get($contact_id, $activity_array, $event_fiscalyear);
            wachthond($extdebug,2, "activity_intake_array", $activity_intake_array);
            $refpersoon_activity_id = $activity_intake_array['activity_id'] ?? NULL;

            wachthond($extdebug,4, 'intake_array',                      $intake_array);
            wachthond($extdebug,4, 'ontvangst activity_array',          $activity_array);
            wachthond($extdebug,4, 'new_refpersoon_actstatus',          $new_refpersoon_actstatus);

            // CREATE ACTIVITY
            if (empty($refpersoon_activity_id)) {
                $refpersoon_activity_id = intake_activity_create($contact_id, $activity_array, $event_array, $intake_array, $groupID);
                wachthond($extdebug,3, "intake_activity_create - refpersoon", "[NEW ACTID: $refpersoon_activity_id]");
            }

            // UPDATE ACTIVITY
            if ($refpersoon_activity_id AND $new_refpersoon_actstatus) {
                $activity_array['activity_id']          = $refpersoon_activity_id;
                $activity_array['activity_date_time']   = $new_refpersoon_actdatum;
                $activity_array['activity_status_name'] = $new_refpersoon_actstatus;
                $activity_array['activity_prioriteit']  = $new_refpersoon_actprio;                
                $intake_activity_update = intake_activity_update($contact_id, $activity_array, $event_array, $intake_array, $groupID);
                wachthond($extdebug,3, "intake_activity_update", "[NEW ACTID: $intake_activity_update]");
            }
        }

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE PART REF [PRE] 3.2 GET & UPDATE ACTIVITY",     "[REFFEEDBACK]");
        wachthond($extdebug,2, "########################################################################");

        if ($new_refverzoek_actstatus) {

            // GET ACTIVITY
            $activity_array['activity_type_id']         = 117;              // ref_verzoek
            $activity_array['activity_type_naam']       = 'ref_verzoek';    // 117
            $activity_array['activity_subject']         = 'REF feedback ontvangen';
            $activity_intake_array  = intake_activity_get($contact_id, $activity_array, $event_fiscalyear);
            wachthond($extdebug,2, "activity_intake_array", $activity_intake_array);
            $refverzoek_activity_id = $activity_intake_array['activity_id'] ?? NULL;

            wachthond($extdebug,4, 'intake_array',                      $intake_array);
            wachthond($extdebug,4, 'ontvangst activity_array',          $activity_array);
            wachthond($extdebug,4, 'new_refverzoek_actstatus',          $new_refverzoek_actstatus);

            if ($referentie_cid) {
                $activity_array['activity_assignee']    = $referentie_cid;
            }

            // CREATE ACTIVITY
            if (empty($refverzoek_activity_id)) {
                $refverzoek_activity_id = intake_activity_create($contact_id, $activity_array, $event_array, $intake_array, $groupID);
                wachthond($extdebug,3, "intake_activity_create - refverzoek", "[NEW ACTID: $refverzoek_activity_id]");
            }

            // UPDATE ACTIVITY
            if ($refverzoek_activity_id AND $new_refverzoek_actstatus) {
                $activity_array['activity_id']          = $refverzoek_activity_id;
                $activity_array['activity_date_time']   = $new_refverzoek_actdatum;
                $activity_array['activity_status_name'] = $new_refverzoek_actstatus;
                $activity_array['activity_prioriteit']  = $new_refverzoek_actprio;                
                $intake_activity_update = intake_activity_update($contact_id, $activity_array, $event_array, $intake_array, $groupID);
                wachthond($extdebug,3, "intake_activity_update", "[NEW ACTID: $intake_activity_update]");
            }
        }

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE PART REF [PRE] 4.0 UPDATE INTAKE CONTACT",        "[$displayname]");
        wachthond($extdebug,2, "########################################################################");

        $params_cont_update = [
            'checkPermissions'  => FALSE,
            'debug' => $apidebug,         
            'reload'=> TRUE,
            'where' => [
                ['id',  '=', $contact_id],
            ],
            'values' => [
                'id' => $contact_id, 
            ],
        ];

        if ($new_cont_refcid)       { $params_cont_update['values']['INTAKE.REF_cid']       = $new_cont_refcid;     }
        if ($new_cont_refnaam)      { $params_cont_update['values']['INTAKE.REF_naam']      = $new_cont_refnaam;    }
        if ($new_cont_refdatum)     { $params_cont_update['values']['INTAKE.REF_datum']     = $new_cont_refdatum;   }
        if ($new_cont_refpersoon)   { $params_cont_update['values']['INTAKE.REF_persoon']   = $new_cont_refpersoon; }
        if ($new_cont_refstatus)    { $params_cont_update['values']['INTAKE.REF_status']    = $new_cont_refstatus;  }

        if ($contact_id) {
            wachthond($extdebug,3, 'params_cont_update',            $params_cont_update);
            $result_part_update = civicrm_api4('Contact','update',  $params_cont_update);
            wachthond($extdebug,9, 'result_cont_update',            $result_cont_update);
        }

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE PART REF [PRE] 5.0 UPDATE INTAKE PART",       "[$displayname]");
        wachthond($extdebug,2, "########################################################################");

        $params_part_update = [
            'checkPermissions'  => FALSE,
            'debug' => $apidebug,         
            'reload'=> TRUE,
            'where' => [
                ['id',  '=', $part_id],
            ],
            'values' => [
                'id'                     => $part_id, 
//              'PART_LEID.trigger_leid' => $today_datetime, 
            ],
        ];

        if ($new_part_refstatus)    { $params_part_update['values']['PART_LEID_INTERN.REF_status'] = $new_part_refstatus;    }

        if ($part_id) {
            wachthond($extdebug,3, 'params_part_update',                $params_part_update);
            $result_part_update = civicrm_api4('Participant','update',  $params_part_update);
            wachthond($extdebug,9, 'result_part_update',                $result_part_update);
        }

        wachthond($extdebug,1, "########################################################################");
        wachthond($extdebug,1, "### INTAKE PART REF [PRE] EINDE", "[groupID: $groupID / op: $op]");
        wachthond($extdebug,1, "########################################################################");
    }

    #########################################################################
    ### INTAKE PART REF [PRE]                                         [EINDE]
    #########################################################################

    #########################################################################
    ### INTAKE PART VOG [PRE]                                         [START]
    #########################################################################

    if (in_array($groupID, $profilepartvog))  {

        $extdebug = $extdebug_part_vog;

        wachthond($extdebug,1, "########################################################################");
        wachthond($extdebug,1, "### INTAKE PART VOG [PRE] 1.1 GET VALUES FROM PARAMS", "[$displayname - groupID: $groupID]");
        wachthond($extdebug,1, "########################################################################");

        wachthond($extdebug,3, "entityid",          $entityID);
        wachthond($extdebug,3, "params (size)",     $arraysize);
/*
        if ($arraysize == 1) {

            wachthond($extdebug,4, "########################################################################");
            wachthond($extdebug,4, "### INTAKE PART VOG [PRE] 1.1 params array too small > EXIT", "[params: $params]");
            wachthond($extdebug,4, "########################################################################");

            wachthond($extdebug,4, "params",        $params);

            return;

        } else {
            wachthond($extdebug,4, "params",        $params);
        }
*/
        foreach($params as $i=>$item) {

            if ( !isset($indexed[$i][$item['id']]) ) {
                $indexed[$i]['key']         = $i;
//              $indexed[$i]['entity_id']   = $item['entity_id']    ?? NULL;
                $indexed[$i]['column_name'] = $item['column_name']  ?? NULL;
//              $indexed[$i]['table_name']  = $item['table_name']   ?? NULL;
                $indexed[$i]['value']       = $item['value']        ?? NULL;
            }

            if (!isset($key_datum_vogverzoek[$i])  AND $item['column_name'] == "datum_verzoek_599"  ) {   $all_datum_vogverzoek[]   = $i;}
            if (!isset($key_datum_vogaanvraag[$i]) AND $item['column_name'] == "datum_aanvraag_600" ) {   $all_datum_vogaanvraag[]  = $i;}
            if (!isset($key_datum_vognieuw[$i])    AND $item['column_name'] == "datum_vognieuw_603" ) {   $all_datum_vognieuw[]     = $i;}
        }

        wachthond($extdebug,4, "indexed", $indexed);

        $key_datum_vogverzoek   = $all_datum_vogverzoek[0];
        $key_datum_vogaanvraag  = $all_datum_vogaanvraag[0];
        $key_datum_vognieuw     = $all_datum_vognieuw[0];

        wachthond($extdebug,3, "key_datum_vogverzoek",  $key_datum_vogverzoek);
        wachthond($extdebug,3, "key_datum_vogaanvraag", $key_datum_vogaanvraag);
        wachthond($extdebug,3, "key_datum_vognieuw",    $key_datum_vognieuw);

        ##########################################################################################
        ### GET DATUM VOG VERZOEK
        ##########################################################################################        

        if ($key_datum_vogverzoek >= 0) {
            $raw_datum_vogverzoek  = $params[$key_datum_vogverzoek]['value']        ?? NULL;
            if ($raw_datum_vogverzoek) {
                $val_datum_vogverzoek    = date("Y-m-d H:i:s", strtotime($raw_datum_vogverzoek)); 
            } else {
                $val_datum_vogverzoek    = NULL; 
            }
            wachthond($extdebug,2, "val_datum_vogverzoek", $val_datum_vogverzoek);
        }

        ##########################################################################################
        ### GET DATUM VOG AANVRAAG
        ##########################################################################################        

        if ($key_datum_vogaanvraag >= 0) {
            $raw_datum_vogaanvraag  = $params[$key_datum_vogaanvraag]['value']        ?? NULL;
            if ($raw_datum_vogaanvraag) {
                $val_datum_vogaanvraag    = date("Y-m-d H:i:s", strtotime($raw_datum_vogaanvraag)); 
            } else {
                $val_datum_vogaanvraag    = NULL; 
            }
            wachthond($extdebug,2, "val_datum_vogaanvraag", $val_datum_vogaanvraag);
        }

        ##########################################################################################
        ### GET DATUM VOG NIEUW
        ##########################################################################################        

        if ($key_datum_vognieuw >= 0) {
            $raw_datum_vognieuw  = $params[$key_datum_vognieuw]['value']        ?? NULL;
            if ($raw_datum_vognieuw) {
                $val_datum_vognieuw    = date("Y-m-d H:i:s", strtotime($raw_datum_vognieuw)); 
            } else {
                $val_datum_vognieuw    = NULL; 
            }
            wachthond($extdebug,2, "val_datum_vognieuw", $val_datum_vognieuw);
        }

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE PART VOG [PRE] 1.1 CONSOLIDATE VOG DATUMS",   "[$displayname]");
        wachthond($extdebug,2, "########################################################################");

        $val_cont_vognodig      =   NULL;
        $val_cont_vogstatus     =   NULL;
        $val_cont_voglaatste    =   NULL;

        $val_part_vogverzoek    =   $val_datum_vogverzoek;
        $val_part_vogaanvraag   =   $val_datum_vogaanvraag;
        $val_part_vogdatum      =   $val_datum_vognieuw;

        $array_intake_vogall    = array(
            'grensvognoggoed'               =>  $grensvognoggoed,

            'val_cont_vognodig'             =>  $val_cont_vognodig,
            'val_cont_vogstatus'            =>  $val_cont_vogstatus,
            'val_cont_voglaatste'           =>  $val_cont_voglaatste,

            'val_part_vogverzoek'           =>  $val_part_vogverzoek,
            'val_part_vogaanvraag'          =>  $val_part_vogaanvraag,
            'val_part_vogdatum'             =>  $val_part_vogdatum,

            'cont_vog_nodig'                =>  $cont_vognodig,
            'cont_vog_status'               =>  $cont_vogstatus,
            'cont_vog_laatste'              =>  $cont_voglaatste,

            'part_vog_verzoek'              =>  $part_vogverzoek,
            'part_vog_reminder'             =>  $part_vogreminder,
            'part_vog_aanvraag'             =>  $part_vogaanvraag,
            'part_vog_datum'                =>  $part_vogdatum,
        );

        wachthond($extdebug,4, "event_array",           $event_array);
        wachthond($extdebug,4, "array_allpart_ditjaar", $array_allpart_ditjaar);
        wachthond($extdebug,4, 'array_intake_vogall',   $array_intake_vogall);

        $consolidate_vogdata_array = intake_consolidate_vogdata($contact_id, $array_allpart_ditjaar, $event_array, $array_intake_vogall, $groupID);
        wachthond($extdebug,2, 'consolidate_vogdata_array', $consolidate_vogdata_array);

        $new_cont_vognodig      = $consolidate_vogdata_array['new_cont_vognodig'];
        $new_cont_vogstatus     = $consolidate_vogdata_array['new_cont_vogstatus'];
        $new_cont_voglaatste    = $consolidate_vogdata_array['new_cont_voglaatste'];
        $new_cont_vogverzoek    = $consolidate_vogdata_array['new_cont_vogverzoek'];
        $new_cont_vogaanvraag   = $consolidate_vogdata_array['new_cont_vogaanvraag'];
        $new_cont_vogdatum      = $consolidate_vogdata_array['new_cont_vogdatum'];

        $new_part_vognodig      = $consolidate_vogdata_array['new_part_vognodig'];
        $new_part_vogstatus     = $consolidate_vogdata_array['new_part_vogstatus'];
        $new_part_voglaatste    = $consolidate_vogdata_array['new_part_voglaatste'];
        $new_part_vogverzoek    = $consolidate_vogdata_array['new_part_vogverzoek'];
        $new_part_vogaanvraag   = $consolidate_vogdata_array['new_part_vogaanvraag'];
        $new_part_vogdatum      = $consolidate_vogdata_array['new_part_vogdatum'];

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE PART VOG [PRE] 1.2 BEPAAL WAARDE VOGNODIG",   "[$displayname]");
        wachthond($extdebug,2, "########################################################################");

        wachthond($extdebug,1, 'new_cont_vognodig',         $new_cont_vognodig);
        $new_cont_vognodig = intake_vognodig($contact_id, $array_allpart_ditjaar, $event_array, $array_intake_vogall, $consolidate_vogdata_array, $groupID);
        wachthond($extdebug,1, 'new_cont_vognodig',         $new_cont_vognodig);

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE PART VOG [PRE] 2.1 BEPAAL NEW STATUS ACTIVITEIT VOG VERZOEK");
        wachthond($extdebug,2, "########################################################################");

        wachthond($extdebug,3, 'new_part_vogverzoek',       $new_part_vogverzoek);
        wachthond($extdebug,3, 'part_kampstart',            $part_kampstart);

        if (infiscalyear($new_part_vogverzoek, $part_kampstart) == 1) {    // INFISCALYEAR DITJAAR
            $new_vogverzoek_actstatus   = 'Completed';
            wachthond($extdebug,3, "new_part_vogstatus",        $new_part_vogstatus);
        }
        if (infiscalyear($new_part_vogaanvraag, $part_kampstart) == 1) {    // INFISCALYEAR DITJAAR
            $new_vogverzoek_actstatus   = 'Completed';
            wachthond($extdebug,3, "new_part_vogstatus",        $new_part_vogstatus);
        }
        if (infiscalyear($new_part_vogdatum,    $part_kampstart) == 1) {    // INFISCALYEAR DITJAAR
            $new_vogverzoek_actstatus   = 'Completed';
            wachthond($extdebug,3, "new_part_vogstatus",        $new_part_vogstatus);
        }

        $new_vogverzoek_actdatum = $new_cont_vogverzoek;

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE PART VOG [PRE] 2.2 BEPAAL NEW STATUS ACTIVITEIT VOG AANVRAAG");
        wachthond($extdebug,2, "########################################################################");

        $intake_array = array(
            'vog_status'    => $org_cont_vogstatus,
            'vog_laatste'   => $org_cont_voglaatste,
            'vog_nodig'     => $new_cont_vognodig,
            'vog_verzoek'   => $new_cont_vogverzoek,
            'vog_aanvraag'  => $new_cont_vogaanvraag,
            'vog_datum'     => $new_cont_vogdatum,
        );
        wachthond($extdebug,3, "intake_array",                      $intake_array);

        $intake_status_vogaanvraag_array  = intake_status_vogaanvraag($contact_id, $array_allpart_ditjaar, $event_array, $intake_array, $groupID);
        wachthond($extdebug,2, "intake_status_vogaanvraag_array",   $intake_status_vogaanvraag_array);

        $new_cont_vogstatus         = $intake_status_vogaanvraag_array['new_cont_vogstatus'];
        $new_part_vogstatus         = $intake_status_vogaanvraag_array['new_part_vogstatus'];
        $new_vogaanvraag_actdatum   = $intake_status_vogaanvraag_array['new_vogaanvraag_actdatum'];
        $new_vogaanvraag_actstatus  = $intake_status_vogaanvraag_array['new_vogaanvraag_actstatus'];
        $new_vogaanvraag_actprio    = $intake_status_vogaanvraag_array['new_vogaanvraag_actprio'];

        wachthond($extdebug,4, "new_cont_vogstatus",        $new_cont_vogstatus);
        wachthond($extdebug,4, "new_part_vogstatus",        $new_part_vogstatus);
        wachthond($extdebug,4, "new_vogaanvraag_actdatum",  $new_vogaanvraag_actdatum);
        wachthond($extdebug,4, "new_vogaanvraag_actstatus", $new_vogaanvraag_actstatus);
        wachthond($extdebug,4, "new_vogaanvraag_actprio",   $new_vogaanvraag_actprio);

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE PART VOG [PRE] 2.3 BEPAAL NEW STATUS ACTIVITEIT VOG ONTVANGST");
        wachthond($extdebug,2, "########################################################################");

        $intake_status_vogontvangst_array  = intake_status_vogontvangst($contact_id, $array_allpart_ditjaar, $event_array, $intake_array, $groupID);
        wachthond($extdebug,2, "intake_status_vogontvangst_array",   $intake_status_vogontvangst_array);

        $new_cont_vogstatus         = $intake_status_vogontvangst_array['new_cont_vogstatus'];
        $new_part_vogstatus         = $intake_status_vogontvangst_array['new_part_vogstatus'];
        $new_vogontvangst_actdatum  = $intake_status_vogontvangst_array['new_vogontvangst_actdatum'];        
        $new_vogontvangst_actstatus = $intake_status_vogontvangst_array['new_vogontvangst_actstatus'];
        $new_vogontvangst_actprio   = $intake_status_vogontvangst_array['new_vogontvangst_actprio'];

        wachthond($extdebug,4, "new_cont_vogstatus",        $new_cont_vogstatus);
        wachthond($extdebug,4, "new_part_vogstatus",        $new_part_vogstatus);
        wachthond($extdebug,4, "new_vogontvangst_actdatum", $new_vogontvangst_actdatum);
        wachthond($extdebug,4, "new_vogontvangst_actstatus",$new_vogontvangst_actstatus);
        wachthond($extdebug,4, "new_vogontvangst_actprio",  $new_vogontvangst_actprio);

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE PART VOG [PRE] 3.0 UPDATE  ACTIVITIES", "[$displayname]");
        wachthond($extdebug,2, "########################################################################");

        wachthond($extdebug,3, 'event_fiscalyear', $ditevent_fiscalyear);

        $activity_array = array(
            'displayname'       => $displayname,
            'contact_id'        => $contact_id,
            'activity_source'   => 1, 
            'activity_target'   => $contact_id,
        );

        $intake_array = array(
            'vog_status'        => $org_cont_vogstatus,
            'vog_laatste'       => $org_cont_voglaatste,
            'vog_nodig'         => $new_cont_vognodig,
            'vog_verzoek'       => $new_cont_vogverzoek,
            'vog_aanvraag'      => $new_cont_vogaanvraag,
            'vog_datum'         => $new_cont_vogdatum,
        );

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE PART VOG [PRE] 3.1 GET & UPDATE ACTIVITY",      "[VOGVERZOEK]");
        wachthond($extdebug,2, "########################################################################");

        if ($new_vogverzoek_actstatus) {

            // GET ACTIVITY
            $activity_array['activity_type_id']         = 118;              // vog_verzoek
            $activity_array['activity_type_naam']       = 'vog_verzoek';    // 118  [required]
            $activity_array['activity_subject']         = 'VOG aanvraag verzocht';            
            $activity_intake_array  = intake_activity_get($contact_id, $activity_array, $event_fiscalyear);
            wachthond($extdebug,2, "activity_intake_array", $activity_intake_array);
            $vogverzoek_activity_id = $activity_intake_array['activity_id'] ?? NULL;

            wachthond($extdebug,4, 'intake_array',                      $intake_array);
            wachthond($extdebug,4, 'verzoek activity_array',            $activity_array);
            wachthond($extdebug,4, 'new_vogverzoek_actstatus',          $new_vogverzoek_actstatus);

            // CREATE ACTIVITY
            if (empty($vogverzoek_activity_id)) {
                $vogverzoek_activity_id = intake_activity_create($contact_id, $activity_array, $event_array, $intake_array, $groupID);
                wachthond($extdebug,3, "intake_activity_create",    "[NEW ACTID: $vogverzoek_activity_id]");
            }

            // UPDATE ACTIVITY
            if ($vogverzoek_activity_id AND $new_vogverzoek_actstatus) {
                $activity_array['activity_id']          = $vogverzoek_activity_id;
                $activity_array['activity_date_time']   = $new_vogverzoek_actdatum;
                $activity_array['activity_status_name'] = $new_vogverzoek_actstatus;
                $activity_array['activity_prioriteit']  = $new_vogverzoek_actprio;
                $intake_activity_update = intake_activity_update($contact_id, $activity_array, $event_array, $intake_array, $groupID);
                wachthond($extdebug,3, "intake_activity_update - vogverzoek", "[NEW ACTID: $intake_activity_update]");
            }
        }

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE PART VOG [PRE] 3.2 GET & UPDATE ACTIVITY",     "[VOGAANVRAAG]");
        wachthond($extdebug,2, "########################################################################");

        if ($new_vogaanvraag_actstatus) {

            // GET ACTIVITY
            $activity_array['activity_type_id']         = 119;              // vog_aanvraag
            $activity_array['activity_type_naam']       = 'vog_aanvraag';   // 119  [required]
            $activity_array['activity_subject']         = 'VOG aanvraag ingediend';
            $activity_intake_array  = intake_activity_get($contact_id, $activity_array, $event_fiscalyear);
            wachthond($extdebug,2, "activity_intake_array", $activity_intake_array);
            $vogaanvraag_activity_id = $activity_intake_array['activity_id'] ?? NULL;

            wachthond($extdebug,4, 'intake_array',                      $intake_array);
            wachthond($extdebug,4, 'aanvraag activity_array',           $activity_array);
            wachthond($extdebug,4, 'new_vogaanvraag_actstatus',         $new_vogaanvraag_actstatus);

            // CREATE ACTIVITY
            if (empty($vogaanvraag_activity_id)) {
                $vogaanvraag_activity_id = intake_activity_create($contact_id, $activity_array, $event_array, $intake_array, $groupID);
                wachthond($extdebug,3, "intake_activity_create  - vogaanvraag", "[NEW ACTID: $vogaanvraag_activity_id]");
            }

            // UPDATE ACTIVITY
            if ($vogaanvraag_activity_id AND $new_vogaanvraag_actstatus) {
                $activity_array['activity_id']          = $vogaanvraag_activity_id;
                $activity_array['activity_date_time']   = $new_vogaanvraag_actdatum;
                $activity_array['activity_status_name'] = $new_vogaanvraag_actstatus;
                $activity_array['activity_prioriteit']  = $new_vogaanvraag_actprio;
                $intake_activity_update = intake_activity_update($contact_id, $activity_array, $event_array, $intake_array, $groupID);
                wachthond($extdebug,3, "intake_activity_update", "[NEW ACTID: $intake_activity_update]");
            }
        }

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE PART VOG [PRE] 3.3 GET & UPDATE ACTIVITY",    "[VOGONTVANGST]");
        wachthond($extdebug,2, "########################################################################");

        if ($new_vogontvangst_actstatus) {

            // GET ACTIVITY
            $activity_array['activity_type_id']         = 120;              // vog_ontvangst
            $activity_array['activity_type_naam']       = 'vog_ontvangst';  // 120  [required]
            $activity_array['activity_subject']         = 'VOG ontvangst bevestigd';
            $activity_intake_array  = intake_activity_get($contact_id, $activity_array, $event_fiscalyear);
            wachthond($extdebug,2, "activity_intake_array", $activity_intake_array);
            $vogontvangst_activity_id = $activity_intake_array['activity_id'] ?? NULL;

            wachthond($extdebug,4, 'intake_array',                      $intake_array);
            wachthond($extdebug,4, 'ontvangst activity_array',          $activity_array);
            wachthond($extdebug,4, 'new_vogontvangst_actstatus',        $new_vogontvangst_actstatus);

            // CREATE ACTIVITY
            if (empty($vogontvangst_activity_id)) {
                $vogontvangst_activity_id = intake_activity_create($contact_id, $activity_array, $event_array, $intake_array, $groupID);
                wachthond($extdebug,3, "intake_activity_create - vogontvangst", "[NEW ACTID: $vogontvangst_activity_id]");
            }

            // UPDATE ACTIVITY
            if ($vogontvangst_activity_id AND $new_vogontvangst_actstatus) {
                $activity_array['activity_id']          = $vogontvangst_activity_id;
                $activity_array['activity_date_time']   = $new_vogontvangst_actdatum;
                $activity_array['activity_status_name'] = $new_vogontvangst_actstatus;
                $activity_array['activity_prioriteit']  = $new_vogontvangst_actprio;                
                $intake_activity_update = intake_activity_update($contact_id, $activity_array, $event_array, $intake_array, $groupID);
                wachthond($extdebug,3, "intake_activity_update", "[NEW ACTID: $intake_activity_update]");
            }
        }

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE PART VOG [PRE] 4.0 UPDATE INTAKE PART",           "[$displayname]");
        wachthond($extdebug,2, "########################################################################");

        $params_part_update = [
            'checkPermissions'  => FALSE,
            'debug' => $apidebug,         
            'reload'=> TRUE,
            'where' => [
                ['id',  '=', $part_id],
            ],
            'values' => [
                'id'                     => $part_id, 
//              'PART_LEID.trigger_leid' => $today_datetime, 
            ],
        ];

        if ($new_part_vognodig)     { $params_part_update['values']['PART_LEID_INTERN.VOG_nodig']   = $new_part_vognodig;   }
        if ($new_part_vogstatus)    { $params_part_update['values']['PART_LEID_INTERN.VOG_status']  = $new_part_vogstatus;  }

        if ($part_id) {
            wachthond($extdebug,3, 'params_part_update',                $params_part_update);
            $result_part_update = civicrm_api4('Participant','update',  $params_part_update);
            wachthond($extdebug,9, 'result_part_update',                $result_part_update);
        }

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE PART VOG [PRE] 5.0 UPDATE INTAKE CONTACT",        "[$displayname]");
        wachthond($extdebug,2, "########################################################################");

        $params_cont_update = [
            'checkPermissions'  => FALSE,
            'debug' => $apidebug,         
            'reload'=> TRUE,
            'where' => [
                ['id',  '=', $contact_id],
            ],
            'values' => [
                'id' => $contact_id, 
            ],
        ];

        if ($new_cont_vognodig)     { $params_cont_update['values']['INTAKE.VOG_nodig']     = $new_cont_vognodig;   }
        if ($new_cont_vogdatum)     { $params_cont_update['values']['INTAKE.VOG_laatste']   = $new_cont_vogdatum;   }
        if ($new_cont_vogstatus)    { $params_cont_update['values']['INTAKE.VOG_status']    = $new_cont_vogstatus;  }

        if ($contact_id) {
            wachthond($extdebug,3, 'params_cont_update',            $params_cont_update);
            $result_part_update = civicrm_api4('Contact','update',  $params_cont_update);
            wachthond($extdebug,9, 'result_cont_update',            $result_cont_update);
        }

        wachthond($extdebug,1, "########################################################################");
        wachthond($extdebug,1, "### INTAKE PART VOG [PRE] EINDE", "[groupID: $groupID / op: $op]");
        wachthond($extdebug,1, "########################################################################");
    }

}

function intake_civicrm_custom($op, $groupID, $entityID, &$params) {

    $extdebug           = 0;  //  1 = basic // 2 = verbose // 3 = params / 4 = results
    $apidebug           = FALSE;

    $today_datetime     = date("Y-m-d H:i:s");

    if ($op != 'create' && $op != 'edit') { //    did we just create or edit a custom object?
        wachthond($extdebug,4, "########################################################################");
        wachthond($extdebug,4, "### INT 10.X EXIT: op != create OR op != edit",               "[op: $op]");
        wachthond($extdebug,4, "########################################################################");
        return; //  if not, get out of here
    }

    $profilecont        = array(225);
    $profilepartdeel    = array(139);
    $profilepartleid    = array(190);
    $profilepartref     = array(213);
    $profilepartvog     = array(140);

    if (in_array($groupID, $profilepartref))  {
        return;
    }

    if (!in_array($groupID, $profilepartleid))  {

        wachthond($extdebug,4, "########################################################################");
        wachthond($extdebug,4, "### INT 10.X EXIT: group != partleid",              "[groupID: $groupID]");
        wachthond($extdebug,4, "########################################################################");

        return;
    }

    $profilepart        = array_merge($profilepartdeel, $profilepartleid);
    $profilepartintake  = array_merge($profilepartref,  $profilepartvog);

    $profilecontmax     = array_merge($profilecont);
    $profilepartmax     = array_merge($profilepart,     $profilepartintake);
    $profilepartleidmax = array_merge($profilepartleid, $profilepartintake);
    $profilecv          = array_merge($profilecont,     $profilepart);
    $profilecvmax       = array_merge($profilecontmax,  $profilepartmax);

    if (in_array($groupID, $profilepartleid) OR in_array($groupID, $profilepartintake))  {      // PROFILE CONT & PART (BASIC)

        wachthond($extdebug,1, "########################################################################");
        wachthond($extdebug,1, "### INT 10.X START PROFILE PART INTAKE / VOG / REF", "[groupID: $groupID / op: $op]");
        wachthond($extdebug,1, "########################################################################");

        $processintake  = 1;

        $extact         = 1;  //  ACTIVITIES
        $extint         = 1;  //  EXECUTE OR SKIP INTAKE PART

        $extnaw         = 1;
        $extbio         = 1;

        $extref         = 1;
        $extvog         = 1;

        $extwrite       = 1;

        if (in_array($groupID, $profilepartref)) {
            $extref     = 1;
            $extvog     = 0;
        }
        if (in_array($groupID, $profilepartvog)) {
            $extvog     = 1;
            $extref     = 1;
        }

    } else {
        wachthond($extdebug,4, "########################################################################");
        wachthond($extdebug,4, "### INT 10.X EXIT: groupID ($groupID) not in allowed list (profileintake)", $profileintake);
        wachthond($extdebug,4, "########################################################################");
        return; //  if not, get out of here
    }

    // M61: ZET TIJDELIJK VOG UIT VOOR _CUSTOM
    $extvog         = 0;

    if (in_array($groupID, $profilepartleid) OR in_array($groupID, $profilepartintake))  {      // PROFILE CONT & PART (BASIC)

        wachthond($extdebug,3, "########################################################################");
        wachthond($extdebug,1, "### INT 10.1 GET PARTICIPANT DATA BASED ON PID",       "[PID: $entityID]");
        wachthond($extdebug,3, "########################################################################");

        $array_partditevent = base_pid2part($entityID, $groupID);
        wachthond($extdebug,3, "array_partditevent", $array_partditevent);

        $contact_id                         = $array_partditevent['contact_id']                     ?? NULL;
        wachthond($extdebug,1, "RETRIEVE CONTACT_ID OBV ENTITYID (part_id) $entityID", "contact_id: $contact_id");

        $ditevent_displayname               = $array_partditevent['displayname']                    ?? NULL;
        $ditevent_contact_id                = $array_partditevent['contact_id']                     ?? NULL;
        $ditevent_part_id                   = $array_partditevent['id']                             ?? NULL;
        $ditevent_part_eventid              = $array_partditevent['part_event_id']                  ?? NULL;
        $ditevent_part_role_id              = $array_partditevent['role_id']                        ?? NULL;
        $ditevent_part_status_id            = $array_partditevent['status_id']                      ?? NULL;
        $ditevent_part_status_name          = $array_partditevent['status_name']                    ?? NULL;

        $ditevent_event_id                  = $array_partditevent['event_id']                       ?? NULL;
        $ditevent_event_title               = $array_partditevent['event_title']                    ?? NULL;
        $ditevent_event_type_id             = $array_partditevent['event_type_id']                  ?? NULL;
        $ditevent_event_type_label          = $array_partditevent['event_type_label']               ?? NULL;

        $ditevent_event_start               = $array_partditevent['event_start_date']               ?? NULL;
        $ditevent_event_einde               = $array_partditevent['event_end_date']                 ?? NULL;

        $ditevent_fiscalyear                = $array_partditevent['event_fiscalyear']               ?? NULL;
        $ditevent_fiscalyear_start          = $array_partditevent['fiscalyear_start']               ?? NULL;
        $ditevent_fiscalyear_einde          = $array_partditevent['fiscalyear_einde']               ?? NULL;

        $ditevent_part_kampstart            = $array_partditevent['part_kampstart']                 ?? NULL;
