        wachthond($extdebug,1, "### INT 12.1 CONSOLIDATE NAW DATA", "$displayname [$ditevent_leid_functie $ditevent_part_kampkort]");
        wachthond($extdebug,3, "########################################################################");

        ###########################################################################################
        ### SET DEFAULTS TO CURRENT VALUES
        ###########################################################################################

        $org_cont_nawgecheckt    = $cont_nawgecheckt;
        $org_part_nawgecheckt    = $part_nawgecheckt;
        $new_cont_nawgecheckt    = $cont_nawgecheckt;
        $new_part_nawgecheckt    = $part_nawgecheckt;

        $cont_nawgecheckt_infiscalyear_ditjaar   = infiscalyear($org_cont_nawgecheckt,$today_datetime,      'nawgecheckt','ditjaar');
        $cont_nawgecheckt_infiscalyear_ditevent  = infiscalyear($org_cont_nawgecheckt,$ditevent_event_start,'nawgecheckt','ditevent');
        wachthond($extdebug,2, 'nawgecheckt_infiscalyear_ditjaar',      $cont_nawgecheckt_infiscalyear_ditjaar);
        wachthond($extdebug,2, 'nawgecheckt_infiscalyear_ditevent',     $cont_nawgecheckt_infiscalyear_ditevent);

        ##########################################################################################
        // BEPAAL NIEUWE WAARDEN NAWGECHECKT
        ##########################################################################################

        if ($cont_nawgecheckt_infiscalyear_ditevent == 1) {

            // ALS PART_NAWGECHECKT BESTAAT MAAR CONT NAWGECHECKT NIEUWER IS    (BINNEN FISCALYEAR VAN DIT EVENT)
            if (date_bigger($cont_nawgecheckt, $part_nawgecheckt) == 1) {
                $new_part_nawgecheckt = $cont_nawgecheckt;
                wachthond($extdebug,3, "cont_nawgecheckt [$cont_nawgecheckt] > part_nawgecheckt $part_nawgecheckt", "[cont_nawgecheckt was nieuwer]");
            }
            // ALS PART_NAWGECHECKT BESTAAT EN NIEUWER IS DAN CONT NAWGECHECKT  (BINNEN FISCALYEAR VAN DIT EVENT)
            if (date_bigger($part_nawgecheckt, $cont_nawgecheckt) == 1) {
                $new_cont_nawgecheckt = $part_nawgecheckt;
                wachthond($extdebug,3, "part_nawgecheckt [$part_nawgecheckt] > cont_nawgecheckt $cont_nawgecheckt", "[part_nawgecheckt was nieuwer]");
            }
            // ALS PART_NAWGECHECKT LEEG IS EN CONT NAWGECHECKT BESTAAT         (BINNEN FISCALYEAR VAN DIT EVENT)
            if (empty($part_nawgecheckt)) {
                $new_part_nawgecheckt = $cont_nawgecheckt;
                wachthond($extdebug,3, "cont_nawgecheckt [$cont_nawgecheckt] > part_nawgecheckt $part_nawgecheckt", "[part_nawgecheckt was leeg]");
            }
        }        

        wachthond($extdebug,2, 'new_cont_nawgecheckt',   $new_cont_nawgecheckt);
        wachthond($extdebug,2, 'new_part_nawgecheckt',   $new_part_nawgecheckt);
    }

    if ($extbio == 1 AND in_array($groupID, $profilecvmax) AND ($diteventleidyes == 1 OR $diteventleidstf == 1)) {

        wachthond($extdebug,3, "########################################################################");
        wachthond($extdebug,1, "### INT 12.2 CONSOLIDATE BIO DATA", "$displayname [$ditevent_leid_functie $ditevent_part_kampkort]");
        wachthond($extdebug,3, "########################################################################");

        ###########################################################################################
        ### SET DEFAULTS TO CURRENT VALUES
        ###########################################################################################

        $org_cont_bioingevuld    = $cont_bioingevuld;
        $org_cont_biogecheckt    = $cont_biogecheckt;
        $org_part_biogecheckt    = $part_biogecheckt;
        $new_cont_biogecheckt    = $cont_biogecheckt;
        $new_part_biogecheckt    = $part_biogecheckt;

        ##########################################################################################
        // UPDATE BIO INGEVULD INDIEN LEEG EN BIOGECHECKT WEL INGEVULD IS
        ##########################################################################################
        if ($org_cont_biogecheckt AND empty($org_cont_bioingevuld)) {
            $new_cont_bioingevuld = $new_cont_biogecheckt;
            wachthond($extdebug,3, "bio_ingevuld = leeg en bio_gecheckt = ($new_cont_biogecheckt)", "Update bio_ingevuld");
        }

        $cont_biogecheckt_infiscalyear_ditjaar   = infiscalyear($org_cont_biogecheckt,$today_datetime,      'biogecheckt','ditjaar');
        $cont_biogecheckt_infiscalyear_ditevent  = infiscalyear($org_cont_biogecheckt,$ditevent_event_start,'biogecheckt','ditevent');
        wachthond($extdebug,2, 'biogecheckt_infiscalyear_ditjaar',      $cont_biogecheckt_infiscalyear_ditjaar);
        wachthond($extdebug,2, 'biogecheckt_infiscalyear_ditevent',     $cont_biogecheckt_infiscalyear_ditevent);

        ##########################################################################################
        // BEPAAL NIEUWE WAARDEN BIOGECHECKT
        ##########################################################################################

        if ($cont_biogecheckt_infiscalyear_ditevent == 1) {

            // ALS PART_BIOGECHECKT BESTAAT MAAR CONT BIOGECHECKT NIEUWER IS    (BINNEN FISCALYEAR VAN DIT EVENT)
            if (date_bigger($cont_biogecheckt, $part_biogecheckt) == 1) {
                $new_part_biogecheckt = $cont_biogecheckt;
                wachthond($extdebug,3, "cont_biogecheckt [$cont_biogecheckt] > part_biogecheckt $part_biogecheckt", "[cont_biogecheckt was nieuwer]");
            }
            // ALS PART_BIOGECHECKT BESTAAT EN NIEUWER IS DAN CONT BIOGECHECKT  (BINNEN FISCALYEAR VAN DIT EVENT)
            if (date_bigger($part_biogecheckt, $cont_biogecheckt) == 1) {
                $new_cont_biogecheckt = $part_biogecheckt;
                wachthond($extdebug,3, "part_biogecheckt [$part_biogecheckt] > cont_biogecheckt $cont_biogecheckt", "[part_biogecheckt was nieuwer]");
            }
            // ALS PART_BIOGECHECKT LEEG IS EN CONT BIOGECHECKT BESTAAT         (BINNEN FISCALYEAR VAN DIT EVENT)
            if (empty($part_biogecheckt)) {
                $new_part_biogecheckt = $cont_biogecheckt;
                wachthond($extdebug,3, "cont_biogecheckt [$cont_biogecheckt] > part_biogecheckt $part_biogecheckt", "[part_biogecheckt was leeg]");
            }
        }

        wachthond($extdebug,2, 'new_cont_bioingevuld',   $new_cont_bioingevuld);
        wachthond($extdebug,2, 'new_cont_biogecheckt',   $new_cont_biogecheckt);
        wachthond($extdebug,2, 'new_part_biogecheckt',   $new_part_biogecheckt);
    }

    if ($extref == 1 AND in_array($groupID, $profilecvmax) AND ($diteventleidyes == 1 OR $diteventleidstf == 1)) {

        wachthond($extdebug,3, "########################################################################");
        wachthond($extdebug,1, "### INT 12.3 CONSOLIDATE REF DATA", "$displayname [$ditevent_leid_functie $ditevent_part_kampkort]");
        wachthond($extdebug,3, "########################################################################");

        ###########################################################################################
        ### SET DEFAULTS TO CURRENT VALUES
        ###########################################################################################

        $new_cont_refdatum      = $cont_refdatum;
        $new_part_refdatum      = $part_refdatum;

        $new_cont_refnaam       = $cont_refnaam;
        $new_part_refnaam       = $part_refnaam;

        $new_part_refpersoon    = $part_refpersoon;
        $new_part_refgevraagd   = $part_refgevraagd;
        $new_part_reffeedback   = $part_reffeedback;
        $new_part_refbezwaar    = $part_refbezwaar;

        if ($cont_refdatum) {
            $refrecent_infiscalyear_ditjaar  = infiscalyear($cont_refdatum,$today_datetime,      'refrecent','ditjaar');
            $refrecent_infiscalyear_ditevent = infiscalyear($cont_refdatum,$ditevent_event_start,'refrecent','ditevent');
            wachthond($extdebug,3, "refrecent_infiscalyear_ditjaar",  "$refrecent_infiscalyear_ditjaar\t[refrecent: $cont_refdatum]");
            wachthond($extdebug,3, "refrecent_infiscalyear_ditevent", "$refrecent_infiscalyear_ditevent\t[refrecent: $cont_refdatum]");     
        }

        ###########################################################################################
        ### NIEUWSTE WAARDE REF KOMT UIT PART 
        ###########################################################################################
        if ( ($part_reffeedback   AND empty($cont_refdatum)) OR date_bigger($part_reffeedback, $cont_refdatum) == 1) {

            $new_cont_refdatum   = $part_reffeedback;
            $new_cont_refnaam    = $part_refnaam;

            wachthond($extdebug,2, "WEL UPDATE TAB REFRECENT WANT PART_REFFEEDBACK IS NIEUWER",   $new_cont_refdatum);
        }

        ###########################################################################################
        ### NIEUWSTE WAARDE REF KOMT UIT CONT 
        ###########################################################################################
        if ( ($referentie_feedback  AND empty($cont_refdatum)) OR date_bigger($part_reffeedback, $cont_refdatum) == 1) {

            $new_cont_refdatum = $referentie_feedback;
            wachthond($extdebug,2, "WEL UPDATE TAB REFRECENT WANT REFERENTIE_FEEDBACK IS NIEUWER",  $new_cont_refdatum);
        }

        ###########################################################################################
        ### DATUM INTAKE REFPERSOON IS LEEG: VUL MET LAATSTE WAARDE REF FEEDBACK 
        ###########################################################################################
        if ( empty($refpersoon) AND !empty($new_cont_refdatum) ) {

            $new_cont_refpersoon = $new_cont_refdatum;
            wachthond($extdebug,2, "WEL UPDATE TAB REFPERSOON WANT LEEG. UPDATE MET REFRECENT",   $new_cont_refpersoon);
        }

        ###########################################################################################
        # ZET VARIABLE REFVERZOEKDITJAAR INDIEN VERZOEK DIT JAAR TBV CONDITIES VERDEROP
        ###########################################################################################

        $refverzoekditjaar = 0;
        if (infiscalyear($part_refgevraagd,$ditevent_event_start,'part_refgevraagd','ditevent') == 1) {
            $refverzoekditjaar = 1;
        }
        wachthond($extdebug,2, 'refverzoekditjaar', "$refverzoekditjaar $part_refgevraagd");

        if ($extref == 1 AND $result_ref_get_refcount == 1 AND ($ditjaareventleidmss == 1 OR $ditjaareventleidyes == 1)) {

            wachthond($extdebug,3, "########################################################################");
            wachthond($extdebug,1, "### INT 12.3 C UPDATE INTAKE GEGEVENS IN PART LEID REF VOOR $displayname", "[groupID: $groupID]");
            wachthond($extdebug,3, "########################################################################");

            if (infiscalyear($referentie_start,$ditevent_event_start,'referentie_start','ditevent') == 1) {
                $new_part_refpersoon  = $referentie_start;
                wachthond($extdebug,1, "PART_REF_PERSOON LEEG MAAR DATUM REL_PERSOON_START IN FISCAL YEAR EVENT", "[referentie_start: $referentie_start]");
            }
            if (infiscalyear($referentie_einde,$ditevent_event_einde,'referentie_einde','ditevent') == 1) {
                $new_part_refpersoon  = $ditevent_fiscalyear_start;
                wachthond($extdebug,1, "PART_REF_PERSOON LEEG MAAR DATUM REL_PERSOON_EINDE IN FISCAL YEAR EVENT", "[referentie_start: $ditevent_fiscalyear_start]");
            }
            if (infiscalyear($referentie_gevraagd,$ditevent_event_start,'referentie_gevraagd', 'ditevent') == 1) {
                $new_part_refgevraagd = $referentie_gevraagd;
                wachthond($extdebug,1, "PART_REF_GEVRAAGD LEEG MAAR REL_GEVRAAGD INGEVULD", "[referentie_gevraagd: $referentie_gevraagd]");
            }
            if (infiscalyear($referentie_feedback,$ditevent_event_start,'referentie_feedback', 'ditevent') == 1) {
                $new_part_reffeedback = $referentie_feedback;
                wachthond($extdebug,1, "PART_REF_FEEDBACK LEEG MAAR REL_FEEDBACK INGEVULD", "[referentie_feedback: $referentie_feedback]");
            }
            if (!empty($referentie_bezwaar)) {
                $new_part_refbezwaar  = $referentie_bezwaar;
                wachthond($extdebug,1, "PART_REF_BEZWAAR LEEG MAAR REL_BEZWAAR INGEVULD", "[referentie_bezwaar: $referentie_bezwaar]");
            }
        }

        wachthond($extdebug,2, 'new_cont_refdatum',     $new_cont_refdatum);
        wachthond($extdebug,2, 'new_cont_refnaam',      $new_cont_refnaam);
        wachthond($extdebug,2, 'new_cont_refpersoon',   $new_cont_refpersoon);

        wachthond($extdebug,2, 'new_part_refpersoon',   $new_part_refpersoon);
        wachthond($extdebug,2, 'new_part_refgevraagd',  $new_part_refgevraagd);
        wachthond($extdebug,2, 'new_part_reffeedback',  $new_part_reffeedback);
        wachthond($extdebug,2, 'new_part_refbezwaar',   $new_part_refbezwaar);

        wachthond($extdebug,2, 'referentie_feedback',   $referentie_feedback);
        wachthond($extdebug,2, 'referentie_bezwaar',    $referentie_bezwaar);

    }

    if ($extvog == 123 AND in_array($groupID, $profilecvmax) AND ($diteventleidyes == 1 OR $diteventleidstf == 1)) {

        wachthond($extdebug,3, "########################################################################");
        wachthond($extdebug,1, "### INT 12.4 CONSOLIDATE VOG DATA", "$displayname [$ditevent_leid_functie $ditevent_part_kampkort]");
        wachthond($extdebug,3, "########################################################################");

        ###########################################################################################
        ### SET DEFAULTS TO CURRENT VALUES
        ###########################################################################################

        $org_cont_vogdatum      = $cont_vogdatum;
        $new_cont_vogdatum      = $cont_vogdatum;

        $org_part_vogverzoek    = $part_vogverzoek;
        $org_part_vogaanvraag   = $part_vogaanvraag;
        $org_part_vogdatum      = $part_vogdatum;

        $new_part_vogverzoek    = $part_vogverzoek;
        $new_part_vogaanvraag   = $part_vogaanvraag;
        $new_part_vogdatum      = $part_vogdatum;

        // IF VOG DATUM DOORGEGEVEN & VOG INGEDIEND LEEG VUL DIE MET DATUM VOG VERZOEK
        if (empty($part_vogaanvraag)   AND $part_vogdatum) {
            $part_vogaanvraag = $part_vogverzoek;
        }

        ###########################################################################################
        # PART VOGDATUM IS GROTER DAN CONT VOGRECENT OF VOGRECENT IS LEEG
        ###########################################################################################

        if ( ($part_vogdatum            AND empty($cont_vogdatum)) OR date_bigger($part_vogdatum, $cont_vogdatum) == 1) {

            $new_cont_vogdatum      = $part_vogdatum;

            wachthond($extdebug,2, "WEL UPDATE CONT_VOGRECENT WANT PART_VOGDATUM IS NIEUWER",        $part_vogdatum);
        } else {
            wachthond($extdebug,2, "GEEN UPDATE CONT_VOGRECENT WANT PART_VOGDATUM IS NIET NIEUWER",  $part_vogdatum);
        }

        if (empty($part_vogaanvraag)   AND infiscalyear($part_vogdatum,$ditevent_event_start,'part_vogdatum','ditevent') == 1) {
            $new_part_vogaanvraag   = $part_vogdatum;
            wachthond($extdebug,1, "VOGAANVRAAG LEEG MAAR VOGDATUM INGEVULD", "[part_vogdatum: $part_vogdatum]");
        }

        ###########################################################################################
        # ZET VARIABLE VOGVERZOEKDITJAAR INDIEN VERZOEK DIT JAAR TBV CONDITIES VERDEROP
        ###########################################################################################

        $vogverzoekditjaar = 0;
        if (infiscalyear($part_vogverzoek,$ditevent_event_start,'part_vogverzoek','ditevent') == 1) {
            $vogverzoekditjaar = 1;
        }
        wachthond($extdebug,2, 'vogverzoekditjaar', "$vogverzoekditjaar $part_vogverzoek");

        wachthond($extdebug,3, 'new_cont_vogdatum',         $new_cont_vogdatum);
        wachthond($extdebug,3, 'new_part_vogdatum',         $new_part_vogdatum);
        wachthond($extdebug,3, 'new_part_vogverzoek',       $new_part_vogverzoek);
        wachthond($extdebug,3, 'new_part_vogaanvraag',      $new_part_vogaanvraag);
    }

    // M61: TODO & TO CHECK: NU TIJDELIJK ALLEEN INTAKE DEEL ALS DIE HET EVENT IS VAN DIT HUIDIGE JAAR
    if ($extint == 1 AND in_array($groupID, $profilecvmax) AND ($diteventleidyes == 1 OR $diteventleidstf == 1)) {

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INT 13.1 BEPAAL WAARDEN 'NODIG' VOOR $displayname", "[groupID: $groupID]");
        wachthond($extdebug,2, "########################################################################");

        ###########################################################################################
        ### SET DEFAULTS TO CURRENT VALUES
        ###########################################################################################

        $new_cont_intnodig = $cont_intnodig;
        $new_cont_nawnodig = $cont_nawnodig;
        $new_cont_bionodig = $cont_bionodig;
        $new_cont_refnodig = $cont_refnodig;
        $new_cont_refnodig = $cont_vognodig;

        $new_part_intnodig = $part_intnodig;
        $new_part_nawnodig = $part_nawnodig;
        $new_part_bionodig = $part_bionodig;
        $new_part_refnodig = $part_refnodig;
        $new_part_refnodig = $part_vognodig;

        ###########################################################################################
        ### A. BEPAAL NAW NODIG > Overrule naw nodig naar jaarlijkse check voor iedereen
        ###########################################################################################

        $new_cont_nawnodig = 'elkjaar';
        $new_part_nawnodig = 'elkjaar';

        ###########################################################################################
        ### B. BEPAAL NAW NODIG > Overrule naw nodig naar jaarlijkse check voor iedereen
        ###########################################################################################

        $new_cont_bionodig = 'elkjaar';
        $new_part_bionodig = 'elkjaar';

        wachthond($extdebug,3, "########################################################################");
        wachthond($extdebug,1, "### INT 13.3 BEPAAL WAARDE REFNODIG VOOR $displayname", "[$ditevent_leid_functie $ditevent_event_kampkort]");
        wachthond($extdebug,3, "########################################################################");

        wachthond($extdebug,3, 'cont_refdatum',             $cont_refdatum);
        wachthond($extdebug,3, 'grensrefnoggoed',           $grensrefnoggoed);

        if ($cont_refdatum) {
            $refrecent_infiscalyear_ditjaar  = infiscalyear($cont_refdatum, $today_datetime,      'refrecent','ditjaar');
            $refrecent_infiscalyear_ditevent = infiscalyear($cont_refdatum, $ditevent_event_start,'refrecent','ditevent');
            wachthond($extdebug,3, "refrecent_infiscalyear_ditjaar",  "$refrecent_infiscalyear_ditjaar\t[refrecent: $cont_refdatum]");
            wachthond($extdebug,3, "refrecent_infiscalyear_ditevent", "$refrecent_infiscalyear_ditevent\t[refrecent: $cont_refdatum]");       

            $refrecent_binnengrens = date_biggerequal($cont_refdatum, $grensrefnoggoed, 'refrecent', 'grensref');
            $refrecent_buitengrens = date_biggerequal($grensrefnoggoed, $cont_refdatum, 'grensref',  'refrecent');
            wachthond($extdebug,3, "refrecent_binnengrens",       "$refrecent_binnengrens\t[refrecent: $cont_refdatum]");
            wachthond($extdebug,3, "refrecent_buitengrens",       "$refrecent_buitengrens\t[refrecent: $cont_refdatum]");
        }

        if ($part_refdatum) {
            $part_refdatum_infiscalyear_ditjaar  = infiscalyear($part_refdatum, $today_datetime,      'part_refdatum','ditjaar');
            $part_refdatum_infiscalyear_ditevent = infiscalyear($part_refdatum, $ditevent_event_start,'part_refdatum','ditevent');
            wachthond($extdebug,3, "part_refdatum_infiscalyear_ditjaar", "$part_refdatum_infiscalyear_ditjaar\t[part_refdatum: $part_refdatum]");
            wachthond($extdebug,3, "part_refdatum_infiscalyear_ditevent","$part_refdatum_infiscalyear_ditevent\t[part_refdatum: $part_refdatum]");
        }

        // REFRECENT NIET IN DIT JAAR, WEL BINNEN GRENSNOGGOED
        if ($refrecent_binnengrens == 1 AND $refrecent_infiscalyear_ditjaar != 1) {
            $new_cont_refnodig   = 'noggoed';
        }
        // REFRECENT VALT BUITEN GRENS NOGGOED
        if ($refrecent_buitengrens == 1) {
            $new_cont_refnodig   = 'opnieuw';
        }
        // ALS ER GEEN REF RECENT DATUM IS DAN IS DEZE DUS NODIG
        if (empty($cont_refdatum)) {
            $new_cont_refnodig   = 'eerstex';            
        }
        // HOOFDLEIDING & BESTUUR ELK JAAR
        if (in_array($ditevent_leid_functie, array('hoofdleiding', 'bestuurslid'))) {
            $new_cont_refnodig   = 'elkjaar';
        }

        if (empty($group_bestuur_member)) {
            $aclgroup_bestuur       = 455;  // M61: hardcoded id of (manual) ACL group ditjaar_bestuur
            $group_bestuur          = acl_group_get($contact_id, $aclgroup_bestuur, 'bestuur');
            $group_bestuur_member   = $group_bestuur['group_member'];
        }
        if ($group_bestuur_member == 1) {
            $new_cont_refnodig   = 'elkjaar';
        }

        wachthond($extdebug,3, "########################################################################");
        wachthond($extdebug,1, "### INT 13.4 BEPAAL WAARDE VOGNODIG VOOR $displayname", "[$ditevent_leid_functie $ditevent_event_kampkort]");
        wachthond($extdebug,3, "########################################################################");

        wachthond($extdebug,3, 'cont_vogdatum',     $cont_vogdatum);
        wachthond($extdebug,3, 'grensvognoggoed',   $grensvognoggoed);

        if ($cont_vogdatum) {
            $vogrecent_infiscalyear_ditjaar  = infiscalyear($cont_vogdatum, $today_datetime,      'vogrecent','ditjaar');
            $vogrecent_infiscalyear_ditevent = infiscalyear($cont_vogdatum, $ditevent_event_start,'vogrecent','ditevent');
            wachthond($extdebug,3, "vogrecent_infiscalyear_ditjaar",  "$vogrecent_infiscalyear_ditjaar\t[vogrecent: $cont_vogdatum]");
            wachthond($extdebug,3, "vogrecent_infiscalyear_ditevent", "$vogrecent_infiscalyear_ditevent\t[vogrecent: $cont_vogdatum]");       

            $vogrecent_binnengrens = date_biggerequal($cont_vogdatum, $grensvognoggoed, 'vogrecent', 'grensvog');
            $vogrecent_buitengrens = date_biggerequal($grensvognoggoed, $cont_vogdatum, 'grensvog',  'vogrecent');
            wachthond($extdebug,3, "vogrecent_binnengrens",       "$vogrecent_binnengrens\t[vogrecent: $cont_vogdatum]");
            wachthond($extdebug,3, "vogrecent_buitengrens",       "$vogrecent_buitengrens\t[vogrecent: $cont_vogdatum]");
        }

        if ($part_vogdatum) {
            $part_vogdatum_infiscalyear_ditjaar  = infiscalyear($part_vogdatum, $today_datetime,      'part_vogdatum','ditjaar');
            $part_vogdatum_infiscalyear_ditevent = infiscalyear($part_vogdatum, $ditevent_event_start,'part_vogdatum','ditevent');
            wachthond($extdebug,3, "part_vogdatum_infiscalyear_ditjaar", "$part_vogdatum_infiscalyear_ditjaar\t[part_vogdatum: $part_vogdatum]");
            wachthond($extdebug,3, "part_vogdatum_infiscalyear_ditevent","$part_vogdatum_infiscalyear_ditevent\t[part_vogdatum: $part_vogdatum]");
        }

        // REFRECENT NIET IN DIT JAAR, WEL BINNEN GRENSNOGGOED
        if ($vogrecent_binnengrens == 1 AND $vogrecent_infiscalyear_ditjaar != 1) {
            $new_cont_vognodig   = 'noggoed';
        }
        // REFRECENT VALT BUITEN GRENS NOGGOED
        if ($vogrecent_buitengrens == 1) {
            $new_cont_vognodig   = 'opnieuw';
        }
        // ALS ER GEEN VOG RECENT DATUM IS DAN IS DEZE DUS NODIG
        if (empty($cont_vogdatum)) {
            $new_cont_vognodig   = 'eerstex';            
        }
        // HOOFDLEIDING & BESTUUR ELK JAAR
        if (in_array($ditevent_leid_functie, array('hoofdleiding', 'bestuurslid'))) {
            $new_cont_vognodig   = 'elkjaar';
        }

        if (empty($group_bestuur_member)) {
            $aclgroup_bestuur       = 455;  // M61: hardcoded id of (manual) ACL group ditjaar_bestuur
            $group_bestuur          = acl_group_get($contact_id, $aclgroup_bestuur, 'bestuur');
            $group_bestuur_member   = $group_bestuur['group_member'];
        }
        if ($group_bestuur_member == 1) {
            $new_cont_vognodig   = 'elkjaar';
        }

        wachthond($extdebug,3, "########################################################################");
        wachthond($extdebug,1, "### INT 13.5 FORCEER INTNODIG & VOGNODIG IN SOMMIGE GEVALLEN $displayname", "[groupID: $groupID]");
        wachthond($extdebug,3, "########################################################################");

        ###########################################################################################
        # PAS REFNODIG NOG AAN IN SOMMIGE GEVALLEN N.A.V VOGNODIG
        ###########################################################################################

        // M61 trek refnodig gelijk met vognodig voor leiding vaker dan 9 (totdat alles weer gelijk is)
        if (empty($cont_refdatum)   AND in_array($new_cont_vognodig, array("noggoed")) AND $curcv_keer_leid >= 5) {
            $new_cont_refnodig     = 'noggoed';
        }
        // M61 trek refnodig gelijk met vognodig voor leiding vaker dan 2
        if ($cont_refdatum          AND in_array($new_cont_vognodig, array("noggoed")) AND $curcv_keer_leid > 2) {
            $new_cont_refnodig     = 'noggoed';
        }

        ###########################################################################################
        # BEPAAL DE WAARDE VAN INTAKE NODIG
        ###########################################################################################

        ### STATUS EERSTE KEER
        if ($new_cont_vognodig == 'eerstex') {   // M61: TREK INTNODIG GELIJK MET VOGNODIG
            $new_cont_intnodig  = 'eerstex';
            wachthond($extdebug,1, "INDIEN VOGNODIG eerstex dan ook intnodig en refnodig", $new_cont_intnodig);
        }
        ### STATUS NOG GOED
        if ($new_cont_vognodig == 'noggoed') {   // M61: TREK INTNODIG GELIJK MET VOGNODIG
//          $new_cont_intnodig  = 'noggoed';
//          wachthond($extdebug,1, "INDIEN VOGNODIG noggoed dan ook intnodig", $new_cont_intnodig);
        }
        ### STATUS OPNIEUW
        if ($new_cont_vognodig == 'opnieuw') {   // M61: TREK INTNODIG GELIJK MET VOGNODIG
            $new_cont_intnodig  = 'opnieuw';
            wachthond($extdebug,1, "INDIEN VOGNODIG opnieuw dan ook intnodig", $new_cont_intnodig);
        }

        ###########################################################################################
        ### INDIEN HOOFDLEIDING OF STAF
        ###########################################################################################

        wachthond($extdebug,3, "ditevent_leid_functie", $ditevent_leid_functie);

        if (in_array($ditevent_leid_functie, array('hoofdleiding', 'bestuurslid'))) {
            $new_cont_intnodig  = 'elkjaar';
            $new_cont_refnodig  = 'elkjaar';
            $new_cont_vognodig  = 'elkjaar';
            wachthond($extdebug,1, "INDIEN hoofdleiding of staf intnodig en vognodig elkjaar",       "$new_cont_intnodig ($ditevent_leid_functie)");
        }

        wachthond($extdebug,3, "########################################################################");
        wachthond($extdebug,1, "### INT 13.6 KOPIEER DITJAAR NODIG NAAR PART NODIG VOOR $displayname", "[groupID: $groupID]");
        wachthond($extdebug,3, "########################################################################");

        // INDIEN DITEVENT = DITJAAR PLAATS DAN WAARDE NODIG IN PART
        if ($ditjaareventleidyes == 1 OR $ditjaareventleidstf == 1) {
            $new_part_intnodig   = $new_cont_intnodig;
            $new_part_nawnodig   = $new_cont_nawnodig;
            $new_part_bionodig   = $new_cont_bionodig;
            $new_part_refnodig   = $new_cont_refnodig;
            $new_part_vognodig   = $new_cont_vognodig;
        }

        wachthond($extdebug,3, "new_cont_intnodig",      $new_cont_intnodig);
        wachthond($extdebug,3, "new_part_intnodig",      $new_part_intnodig);
        wachthond($extdebug,3, "new_cont_nawnodig",      $new_cont_nawnodig);
        wachthond($extdebug,3, "new_part_nawnodig",      $new_part_nawnodig);
        wachthond($extdebug,3, "new_cont_bionodig",      $new_cont_bionodig);
        wachthond($extdebug,3, "new_part_bionodig",      $new_part_bionodig);
        wachthond($extdebug,2, "new_cont_refnodig",      $new_cont_refnodig);
        wachthond($extdebug,2, "new_part_refnodig",      $new_part_refnodig);
        wachthond($extdebug,2, "new_cont_vognodig",      $new_cont_vognodig);
        wachthond($extdebug,2, "new_part_vognodig",      $new_part_vognodig);

        ##########################################################################################
        if ($extnaw == 1 AND in_array($groupID, $profilecvmax)) {           // PROFILE ALLES + VOG
        ##########################################################################################

            wachthond($extdebug,3, "########################################################################");
            wachthond($extdebug,1, "### INT 14.1 BEPAAL DE STATUS NAW $displayname [$ditevent_leid_functie $ditevent_event_kampkort]", "[groupID: $groupID]");
            wachthond($extdebug,3, "########################################################################");

            if ($cont_nawgecheckt_infiscalyear_ditjaar == 1) {
                $new_cont_nawstatus  = 'bijgewerkt';
                wachthond($extdebug,1,  "CONT_NAWGECHECKT [$new_cont_nawgecheckt] IN FISCAL JAAR DIT JAAR",  "> CONT_NAWSTATUS: [$new_cont_nawstatus]");
            } else {
                $new_cont_nawstatus  = 'ongecheckt';
            }

            if ($cont_nawgecheckt_infiscalyear_ditevent == 1) {
                $new_part_nawstatus  = 'bijgewerkt';
                wachthond($extdebug,1,  "CONT_NAWGECHECKT [$new_cont_nawgecheckt] IN FISCAL JAAR VAN EVENT", "> PART_NAWSTATUS: [$new_part_nawstatus]");
            } else {
                $new_part_nawstatus  = 'ongecheckt';
            }

            wachthond($extdebug,3, 'new_cont_nawgecheckt',   $new_cont_nawgecheckt);
            wachthond($extdebug,3, 'new_cont_nawstatus',     $new_cont_nawstatus);
            wachthond($extdebug,3, 'new_part_nawgecheckt',   $new_part_nawgecheckt);
            wachthond($extdebug,3, 'new_part_nawstatus',     $new_part_nawstatus);

        }

        ##########################################################################################
        if ($extbio == 1 AND in_array($groupID, $profilecvmax)) {       // PROFILE ALLES + VOG
        ##########################################################################################

            wachthond($extdebug,3, "########################################################################");
            wachthond($extdebug,1, "### INT 14.2 BEPAAL DE STATUS BIO $displayname [$ditevent_leid_functie $ditevent_event_kampkort]", "[groupID: $groupID]");
            wachthond($extdebug,3, "########################################################################");

            ##########################################################################################
            ### BEPAAL NIEUWE STATUS BIO
            ##########################################################################################

            if ($cont_biogecheckt_infiscalyear_ditjaar == 1) {
                $new_cont_biostatus  = 'bijgewerkt';
                wachthond($extdebug,1,  "CONT_BIOGECHECKT [$new_cont_biogecheckt] IN FISCAL JAAR DIT JAAR",  "> CONT_BIOSTATUS: [$new_cont_biostatus]");
            } else {
                $new_cont_biostatus  = 'ongecheckt';
            }

            if ($cont_biogecheckt_infiscalyear_ditevent == 1) {
                $new_part_biostatus  = 'bijgewerkt';
                wachthond($extdebug,1,  "CONT_BIOGECHECKT [$new_cont_biogecheckt] IN FISCAL JAAR VAN EVENT", "> PART_BIOSTATUS: [$new_part_biostatus]");
            } else {
                $new_part_biostatus  = 'ongecheckt';
            }

            wachthond($extdebug,3, 'new_cont_biogecheckt',   $new_cont_biogecheckt);
            wachthond($extdebug,3, 'new_cont_biostatus',     $new_cont_biostatus);
            wachthond($extdebug,3, 'new_part_biogecheckt',   $new_part_biogecheckt);
            wachthond($extdebug,3, 'new_part_biostatus',     $new_part_biostatus);
        }

        ##########################################################################################
        if ($extref == 1 AND in_array($groupID, $profilecvmax)) {       // PROFILE ALLES + VOG
        ##########################################################################################

            wachthond($extdebug,3, "########################################################################");
            wachthond($extdebug,1, "### INT 14.3 BEPAAL DE STATUS REF $displayname [$ditevent_leid_functie $ditevent_event_kampkort]","[groupID: $groupID]");
            wachthond($extdebug,3, "########################################################################");

            $new_refpersoon_actstatus = 'Available';  // DEFAULT TO AVAILABLE (CONCEPT)
            $new_refverzoek_actstatus = 'Available';  // DEFAULT TO AVAILABLE (CONCEPT)

            // M61: TODO: DIT PRIMAIR HALEN UIT RELATION REFERENTIE IPV WAARDE UIT EVENT. (OOK HANDIG BIJ 2X ALS LEIDING MEE)   

            if ($cont_refdatum) {

                $refrecent_infiscalyear_ditjaar  = infiscalyear($cont_refdatum,$today_datetime,      'refrecent','ditjaar');
                $refrecent_infiscalyear_ditevent = infiscalyear($cont_refdatum,$ditevent_event_start,'refrecent','ditevent');
                wachthond($extdebug,3, "refrecent_infiscalyear_ditjaar",  "$refrecent_infiscalyear_ditjaar\t[refrecent: $cont_refdatum]");
                wachthond($extdebug,3, "refrecent_infiscalyear_ditevent", "$refrecent_infiscalyear_ditevent\t[refrecent: $cont_refdatum]");       

                $refrecent_binnengrens = date_biggerequal($cont_refdatum, $grensrefnoggoed, 'refrecent', 'refgrens');
                $refrecent_buitengrens = date_biggerequal($grensrefnoggoed, $cont_refdatum, 'refgrens',  'refrecent');
                wachthond($extdebug,3, "refrecent_binnengrens",       "$refrecent_binnengrens\t[refrecent: $cont_refdatum]");
                wachthond($extdebug,3, "refrecent_buitengrens",       "$refrecent_buitengrens\t[refrecent: $cont_refdatum]");

                // REFRECENT NIET IN DIT JAAR, WEL BINNEN GRENSNOGGOED
                if ($refrecent_binnengrens == 1 AND $refrecent_infiscalyear_ditjaar == 0) {
                    $new_cont_refstatus  = 'noggoed';
                    wachthond($extdebug,2, "DATUM REF [$cont_refdatum] VALT BINNEN GRENS NOGGOED REF ($grensnoggoedjaar JAAR)",   "[>$grensrefnoggoed]");
                }
                // REFRECENT VALT BUITEN GRENS NOGGOED
                if ($refrecent_buitengrens == 1 OR empty($cont_refdatum)) {
                    $new_cont_refstatus  = 'onbekend';
                    wachthond($extdebug,2, "DATUM REF [$cont_refdatum] VALT BUITEN GRENS NOGGOED REF ($grensnoggoedjaar JAAR)",   "[>$grensrefnoggoed]");
                }
                // REFRECENT DIT JAAR AANGEVRAAGD EN ONTVANNGEN
                if ($refrecent_infiscalyear_ditjaar == 1) {
                    $new_cont_refstatus  = 'ontvangen';
                    wachthond($extdebug,2, "DATUM REF [$cont_refdatum] VALT BINNEN HUIDIGE FISCALE JAAR)",    "[>$today_fiscalyear_start]");
                }
                // INDIEN DITEVENT = DITJAAR PLAATS DAN REF NODIG IN PART
                if ($ditjaareventleidyes == 1 OR $ditjaareventleidstf == 1) {
                    $new_part_refstatus  = $new_cont_refstatus;
                }
                if ($ditjaareventleidyes == 1 OR $ditjaareventleidstf == 1) {
                    $new_part_refstatus  = $new_part_refstatus;
                }

            } else {

                wachthond($extdebug,3, "########################################################################");
                wachthond($extdebug,1, "### INT 14.3 STATUS REF IGV REFRECENT = LEEG");
                wachthond($extdebug,3, "########################################################################");

                $new_cont_refstatus      = 'onbekend'; // basisstatus

            }

            ###########################################################################################
            # BEPAAL STATUS REF VOOR DIT JAAR
            ###########################################################################################

            if (empty($referentie_name))  {
                $new_cont_refstatus = 'onbekend';
            }
            if ($part_refpersoon)     {
                $new_cont_refstatus = 'vragen';
            }
            if ($part_refgevraagd)    {
                $new_cont_refstatus = 'gevraagd';
            }
            if ($part_reffeedback)    {
                $new_cont_refstatus = 'ontvangen';
            }
            if (in_array($new_cont_refnodig, array('noggoed')) AND $referentie_name) {
                $new_cont_refstatus = 'noggoed';
            }

            ###########################################################################################
            # BEPAAL STATUS REF NOG WAT UITZONDERINGEN
            ###########################################################################################

            if ($new_vognodignextyear == 1 AND empty($cont_refdatum) AND $curcv_keer_leid >= 10) {
                $new_refpersoon_actstatus   = 'Not Required';
                $new_cont_refstatus         = 'noggoed';
                wachthond($extdebug,1, "ZET REFSTATUS OP NOGGOED VOOR LEIDING WAARBIJ DIE MIST WAARBIJ VOLGEND JAAR WEER VOG NODIG IS", "[new_cont_refstatus: $new_cont_refstatus]");
            }

            ###########################################################################################
            ### SCENARIO LEIDING KEER MEE >5
            ###########################################################################################

            if (empty($cont_refdatum) AND in_array($new_cont_vognodig, array("noggoed")) AND $curcv_keer_leid >= 5) {
                $new_refpersoon_actstatus   = 'Not Required';
                $new_cont_refstatus         = 'noggoed';
                wachthond($extdebug,1, "TREK REFSTATUS GELIJK MET VOGSTATUS VOOR LEIDING VAKER MEE >=5", "[new_cont_refstatus: $new_cont_refstatus]");
            }
            if (in_array($new_cont_vognodig, array("noggoed")) AND $curcv_keer_leid > 2) {
                $new_refpersoon_actstatus   = 'Not Required';
                $new_cont_refstatus         = 'noggoed';
                wachthond($extdebug,1, "TREK REFNODIG GELIJK MET VOGNODIG VOOR LEIDING VAKER MEE DAN 2", "[new_cont_refstatus: $new_cont_refstatus]");
            }

            ###########################################################################################
            ### GEBRUIK STATUS DITJAAR VOOR DITEVENT INDIEN DIE MATCHEN 
            ###########################################################################################

            if ($ditjaareventleidyes == 1 OR $ditjaareventleidstf == 1) {
                  $new_part_refstatus    = $new_cont_refstatus;
            }

            wachthond($extdebug,3, "new_cont_refnodig",         "$new_cont_refnodig\t($cont_refdatum)");
            wachthond($extdebug,3, "new_part_refnodig",         "$new_part_refnodig\t($cont_refdatum)");
            wachthond($extdebug,3, "new_cont_refstatus",        $new_cont_refstatus);
            wachthond($extdebug,3, "new_part_refstatus",        $new_part_refstatus);
            wachthond($extdebug,3, "new_refpersoon_actstatus",  $new_refpersoon_actstatus);
        }

        ##########################################################################################
        if ($extvog == 123 AND in_array($groupID, $profilecvmax)) {       // PROFILE ALLES + VOG
        ##########################################################################################

            wachthond($extdebug,3, "########################################################################");
            wachthond($extdebug,1, "### INT 14.4 BEPAAL DE STATUS VAN DE VOG", "$displayname [$ditevent_leid_functie $ditevent_part_kampkort]");
            wachthond($extdebug,3, "########################################################################");

            // VOGRECENT NIET IN DIT JAAR, WEL BINNEN GRENSNOGGOED
            if ($vogrecent_binnengrens == 1 AND $vogrecent_infiscalyear_ditjaar == 0) {
                $new_cont_vogstatus  = 'noggoed';
            }
            // VOGRECENT VALT BUITEN GRENS NOGGOED
            if ($vogrecent_buitengrens == 1 OR empty($cont_vogdatum)) {
                $new_cont_vogstatus  = 'klaarzetten';
            }
            // VOGRECENT DIT JAAR AANGEVRAAGD EN ONTVANNGEN
            if ($vogrecent_infiscalyear_ditjaar == 1) {
                $new_cont_vogstatus  = 'ontvangen';
            }
            // INDIEN DITEVENT = DITJAAR PLAATS DAN VOG NODIG IN PART
            if ($ditjaareventleidyes == 1 OR $ditjaareventleidstf == 1) {
                $new_part_vogstatus  = $new_cont_vogstatus;
            }

            wachthond($extdebug,3, "new_cont_vogstatus",         $new_cont_vogstatus);
            wachthond($extdebug,3, "new_part_vogstatus",         $new_part_vogstatus);

        }     

    if ($extref == 1 AND $extact == 1 AND in_array($groupID, $profilepartleidmax) AND $ditjaareventleidyes == 1) {

        wachthond($extdebug,1, "########################################################################");
        wachthond($extdebug,1, "### INT 15.1 x BEPAAL NEW DATUMS VOOR ACTIVITIES REF VOOR $displayname", "[groupID: $groupID]");
        wachthond($extdebug,1, "########################################################################");

        wachthond($extdebug,2, "1. prt_refpersoon",   $part_refpersoon);
        wachthond($extdebug,2, "2. act_refpersoon",   $refpersoon_activity_datum);
        if ($referentie_start) {  wachthond($extdebug,3, "2. rel_refpersoon",   $referentie_start);   }

        wachthond($extdebug,2, "1. prt_refverzoek",   $part_refgevraagd);
        wachthond($extdebug,2, "2. act_refverzoek",   $refverzoek_activity_datum);
        if ($referentie_gevraagd) { wachthond($extdebug,3, "2. rel_refverzoek",   $referentie_gevraagd);  }

        wachthond($extdebug,2, "1. prt_reffeedback",  $part_reffeedback);
        wachthond($extdebug,2, "2. act_reffeedback",  $referentie_feedback);    // M61 er is geen aparte act datum feedback 
        if ($referentie_feedback) { wachthond($extdebug,3, "2. rel_reffeedback",  $referentie_feedback);  }

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INT 15.1 a BEPAAL (NIEUWE) DATUM ACTIVITY REF PERSOON VOOR $displayname", "[groupID: $groupID]");
        wachthond($extdebug,2, "########################################################################");

        $datum_refpersoon                   = NULL;
        $ditjaar_refpersoon_actdatetime     = NULL;

        if (infiscalyear($part_refpersoon,$ditevent_event_start,'part_refpersoon','ditevent') == 1) {
            $datum_refpersoon               = $part_refpersoon;
            $ditjaar_refpersoon_actdatetime = $datum_refpersoon;
            wachthond($extdebug,3, "activity_datum ref_persoon - LOGDATUM = part_refpersoon",   $datum_reffeedback);
        } else {
//          $newdate            = strtotime ('+42 day' , strtotime($ditevent_register_date));
            $newdate            = strtotime ('+42 day' , strtotime($part_vogverzoek));         // M61: Bereken data nav VOG verzoek
            $datum_refpersoon   = date ( 'Y-m-d H:i:s' , $newdate );
            $ditjaar_refpersoon_actdatetime = $datum_refpersoon;
            wachthond($extdebug,3, "activity_datum ref_persoon - DEADLINE = part_regdate +42",  $datum_refpersoon);
        }

        wachthond($extdebug,3, "########################################################################");
        wachthond($extdebug,1, "### INT 15.1 b BEPAAL (NIEUWE) DATUM ACTIVITY REF VERZOEK VOOR $displayname", "[groupID: $groupID]");
        wachthond($extdebug,3, "########################################################################");

        $datum_refverzoek                   = NULL;
        $ditjaar_refverzoek_actdatetime     = NULL;

        if (infiscalyear($part_reffeedback,$ditevent_event_start,'part_reffeedback','ditevent') == 1) {
            $datum_refverzoek   = $part_reffeedback;
            wachthond($extdebug,3, "activity_datum ref_verzoek - LOGDATUM = part_reffeedback",  $datum_reffeedback);
        } elseif (!empty($part_refgevraagd)) {
            $newdate            = strtotime ('+42 day' , strtotime($part_refgevraagd));
            $datum_refverzoek   = date ( 'Y-m-d H:i:s' , $newdate );
            $ditjaar_refverzoek_actdatetime   = $datum_refverzoek;
            wachthond($extdebug,3, "activity_datum ref_verzoek - LOGDATUM = ref_verzoek +42",   $datum_refverzoek);
        } else {
            $datum_refverzoek   = $eventkamp_event_start;
            wachthond($extdebug,3, "activity_datum ref_verzoek - LOGDATUM = eventkamp_start",   $datum_refverzoek);
        }

        wachthond($extdebug,1, "########################################################################");

    } else {
        wachthond($extdebug,1, "########################################################################");
        wachthond($extdebug,3, 'extref',                $extref);
        wachthond($extdebug,3, 'extact',                $extact);
        wachthond($extdebug,3, 'ditjaarleidstf',        $ditjaarleidstf);
        wachthond($extdebug,3, 'ditjaareventleidyes',   $ditjaareventleidyes);
        wachthond($extdebug,3, 'profilepartleidmax',    $profilepartleidmax);
        wachthond($extdebug,1, "### INT 12.1 SKIPPED BEPAAL DE JUISTE DATUMS VOOR ACTIVITIES REF", "[groupID: $groupID]");
    }

    if ($extvog == 123 AND $extact == 1 AND in_array($groupID, $profilepartleidmax) AND $ditjaareventleidyes == 1) {

        wachthond($extdebug,3, "########################################################################");
        wachthond($extdebug,1, "### INT 15.2 a BEPAAL (NIEUWE) DATUM ACTIVITY VOG VERZOEK VOOR $displayname", "[groupID: $groupID]");
        wachthond($extdebug,3, "########################################################################");

        $datum_vogverzoek                       = NULL;
        $new_cont_vogverzoek_actdatetime        = NULL;

        if (infiscalyear($part_vogverzoek, $ditevent_event_start,'part_vogverzoek','ditevent') == 1) {
            $datum_vogverzoek                   = $part_vogverzoek;
            $new_cont_vogverzoek_actdatetime    = $part_vogverzoek;
            wachthond($extdebug,3, "activity_datum vog_verzoek - LOGDATUM = vog verzocht",    $datum_vogverzoek);
        } else {
            $newdate                            = strtotime ('+14 day' , strtotime($ditevent_register_date));
            $datum_vogverzoek                   = date ( 'Y-m-d H:i:s' , $newdate );
            $new_cont_vogverzoek_actdatetime    = $datum_vogverzoek;
            wachthond($extdebug,3, "activity_datum vog_verzoek - LOGDATUM = part_reg_date +14", $datum_vogverzoek);
        }

        wachthond($extdebug,3, "########################################################################");
        wachthond($extdebug,1, "### INT 15.2 b BEPAAL (NIEUWE) DATUM ACTIVITY VOG AANVRAAG VOOR $displayname", "[groupID: $groupID]");
        wachthond($extdebug,3, "########################################################################");

        $datum_vogaanvraag                      = NULL;
        $new_cont_vogaanvraag_actdatetime       = NULL;

        if (infiscalyear($part_vogaanvraag, $ditevent_event_start,'part_vogaanvraag','ditevent') == 1) {
            // M61 TODO: als leiding datum in de toekomst ingaf, dat corrigeren naar datum van verzenden formulier
            $datum_vogaanvraag                  = $part_vogaanvraag;
            $new_cont_vogaanvraag_actdatetime   = $datum_vogaanvraag;
            wachthond($extdebug,3, "activity_datum vog_aanvraag - LOGDATUM = vog ingediend", $datum_vogaanvraag);
        } elseif (infiscalyear($part_vogverzoek, $ditevent_event_start,'part_vogverzoek','ditevent') == 1) {
            $newdate                            = strtotime ( '+30 day' , strtotime ($part_vogverzoek) ) ;
            $datum_vogaanvraag                  = date ( 'Y-m-d H:i:s' , $newdate );
            $new_cont_vogaanvraag_actdatetime   = $datum_vogaanvraag;
            wachthond($extdebug,3, "activity_datum vog_aanvraag - DEADLINE = part_verzocht +42",  $datum_vogaanvraag);
        } else {
            $datum_vogaanvraag                  = $eventkamp_event_start;
            $new_cont_vogaanvraag_actdatetime   = $datum_vogaanvraag;
            wachthond($extdebug,3, "activity_datum vog_aanvraag - LOGDATUM = eventkamp_start",    $datum_vogaanvraag);
        }

        if (infiscalyear($part_vogdatum, $ditevent_event_start,'part_vogdatum','ditevent') == 1 AND empty($part_vogaanvraag)) {  
            $datum_vogaanvraag                  = $part_vogdatum;
            $new_cont_vogaanvraag_actdatetime   = $datum_vogaanvraag;
            wachthond($extdebug,3, "activity_datum vog_aanvraag - LOGDATUM = vogdatum",       $datum_vogaanvraag);
        }

        if (date_bigger($datum_vogaanvraag, $eventkamp_event_start) == 1) {
            wachthond($extdebug,3, "### DATUM ACTIVITY ONTVANGST > EVENT START DATE ###");
            $datum_vogaanvraag                  = $eventkamp_event_start;   // M61: TODO WAAROM EIGENLIJK?
            $new_cont_vogaanvraag_actdatetime   = $datum_vogaanvraag;       // M61: TODO WAAROM EIGENLIJK?
            wachthond($extdebug,3, "activity_datum vog_aanvraag - LOGDATUM = eventkamp_event_einde", $datum_vogaanvraag);
        }

        wachthond($extdebug,3, "########################################################################");
        wachthond($extdebug,1, "### INT 15.2 c BEPAAL (NIEUWE) DATUM ACTIVITY VOG ONTVANGST VOOR $displayname", "[groupID: $groupID]");
        wachthond($extdebug,3, "########################################################################");

        $datum_vogontvangst                 = NULL;
        $new_cont_vogontvangst_actdatetime  = NULL;

        if (infiscalyear($part_vogdatum, $ditevent_event_start,'part_vogdatum','ditevent') == 1) {
            $datum_vogontvangst                     = $part_vogdatum;
            $new_cont_vogontvangst_actdatetime      = $datum_vogontvangst;
            wachthond($extdebug,3, "activity_datum vog_ontvangst - LOGDATUM = datum vog ontvangst", $datum_vogontvangst);
        } elseif (date_bigger($datum_vogontvangst, $eventkamp_event_start) == 1) {
            wachthond($extdebug,3, "### DATUM ACTIVITY ONTVANGST > EVENT START DATE ###");
            $datum_vogontvangst                     = $eventkamp_event_einde;   // M61: TODO WAAROM EIGENLIJK?
            $new_cont_vogontvangst_actdatetime      = $datum_vogontvangst;      // M61: WRS OM DATE DICHT BIJ EVT DATE TE HOUDEN
            wachthond($extdebug,3, "activity_datum vog_ontvangst - LOGDATUM = eventkamp_einde",   $datum_vogontvangst);
        } elseif (infiscalyear($part_vogaanvraag, $ditevent_event_start,'part_vogaanvraag','ditevent') == 1) {
            $newdate                                = strtotime ( '+49 day', strtotime ($part_vogaanvraag) ) ;
            $datum_vogontvangst                     = date ( 'Y-m-d H:i:s' , $newdate );
            $new_cont_vogontvangst_actdatetime      = $datum_vogontvangst;
            wachthond($extdebug,3, "activity_datum vog_ontvangst - DEADLINE = part_ingediend +42",  $datum_vogontvangst);
        } else {
            $datum_vogontvangst                     = $eventkamp_event_einde;
            $new_cont_vogontvangst_actdatetime      = $datum_vogontvangst;
            wachthond($extdebug,3, "activity_datum vog_ontvangst - DEADLINE = eventkamp_start",   $datum_vogontvangst);
        }

    } else {
        wachthond($extdebug,1, "########################################################################");
        wachthond($extdebug,3, 'extvog',              $extvog);
        wachthond($extdebug,3, 'extact',              $extact);
        wachthond($extdebug,3, 'ditjaareventleidstf', $ditjaareventleidstf);
        wachthond($extdebug,3, 'ditjaareventleidyes', $ditjaareventleidyes);
        wachthond($extdebug,3, 'profilepartleidmax',  $profilepartleidmax);
        wachthond($extdebug,1, "### INT 12.2 SKIPPED BEPAAL DE JUISTE DATUMS VOOR ACTIVITIES VOG", "[groupID: $groupID]");
        wachthond($extdebug,4, "########################################################################");
    }

    wachthond($extdebug,1, "########################################################################");
    wachthond($extdebug,1, "### INT 16.X CREATE INTAKE ACTIVITIES VOOR $displayname", "[groupID: $groupID]");
    wachthond($extdebug,4, "########################################################################");

    $activity_array = array(
        'displayname'               => $displayname,
        'contact_id'                => $contact_id,
        'activity_source'           => 1, 
        'activity_target'           => $contact_id,
        'activity_assignee'         => $related_hoofdleiding_id,
        'activity_date_time'        => $today_datetime,
        'activity_status_name'      => 'Available',     // initial status concept
        'activity_prioriteit'       => 'Normaal',
    );

    $intake_array = array(
        'ref_nodig'                 => $new_cont_refnodig,
        'ref_datum_persoon'         => $part_refpersoon,
        'ref_datum_gevraagd'        => $part_refgevraagd,
        'ref_datum_feedback'        => $part_reffeedback,
        'ref_bezwaar'               => $part_refbezwaar,

        'ref_aanvrager_naam'        => $displayname,
        'ref_aanvrager_voornaam'    => $first_name,
        'ref_aanvrager_functie'     => $ditevent_leid_functie,
        'ref_aanvrager_pid'         => $ditevent_part_id,
        'ref_aanvrager_cid'         => $contact_id,

        'ref_rel_id'                => $referentie_relid,
        'ref_referentie_cid'        => $referentie_cid,
        'ref_referentie_naam'       => $referentie_name,
        'ref_referentie_voornaam'   => $referentie_fn,
        'ref_referentie_telefoon'   => $referentie_phone,
    );

    if ($extref == 1 AND $extact == 1 AND in_array($groupID, $profilepartleidmax) AND $ditjaareventleidyes == 1) {

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INT 16.1 CREATE AN ACTIVITY REFPERSOON VOOR $displayname", "[ALS REF PERSOON IS GEVRAAGD]");
        wachthond($extdebug,2, "########################################################################");

        wachthond($extdebug,3, 'refpersoon_activity_id',   $refpersoon_activity_id);

        if (empty($refpersoon_activity_id) AND in_array($new_cont_refnodig,array("eerstex","elkjaar","opnieuw","inhaal"))) {

            $activity_array['activity_type_id']     = 139;
            $activity_array['activity_type_naam']   = 'ref_persoon';
            $activity_array['activity_subject']     = 'REF persoon doorgeven';

            $intake_activity_create = intake_activity_create($contact_id, $activity_array, $event_array, 'ref_persoon');
            wachthond($extdebug,3, "intake_activity_create",    "[NEW ACTID: $intake_activity_create]");
            $refpersoon_activity_id = $intake_activity_create;            

        } else {
            wachthond($extdebug,2, "INFO: Er wordt GEEN activiteit REFPERSOON aangemaakt", "[aid: $refpersoon_activity_id]");
        }

        wachthond($extdebug,3, "########################################################################");
        wachthond($extdebug,1, "### INT 16.2 CREATE AN ACTIVITY REFVERZOEK VOOR $displayname", "[ALS REF PERSOON IS VERZOCHT]");
        wachthond($extdebug,3, "########################################################################");

        if (empty($refverzoek_activity_id) AND in_array($new_cont_refnodig,array("eerstex","elkjaar","opnieuw","inhaal"))) {
//      if (empty($refverzoek_activity_id) AND $part_refgevraagd) {

            $activity_array['activity_type_id']     = 117;
            $activity_array['activity_type_naam']   = 'ref_feedback';
            $activity_array['activity_subject']     = 'REF feedback ontvangen';

            $intake_activity_create = intake_activity_create($contact_id, $activity_array, $event_array, 'ref_verzoek');
            wachthond($extdebug,3, "intake_activity_create",    "[NEW ACTID: $intake_activity_create]");
            $refverzoek_activity_id = $intake_activity_create;

        } elseif ($refverzoek_activity_id > 0) {
            wachthond($extdebug,2, "INFO: Er wordt GEEN activiteit REFVERZOEK aangemaakt", "[aid: $refverzoek_activity_id]");
        } elseif (empty($part_refgevraagd)) {
            wachthond($extdebug,2, "INFO: Er wordt GEEN activiteit REFVERZOEK aangemaakt", "[feedback nog niet gevraagd]");
        }

    } else { 
        wachthond($extdebug,1, "########################################################################");
        wachthond($extdebug,1, 'extref',                  $extref);
        wachthond($extdebug,1, 'extact',                  $extact);
        wachthond($extdebug,1, 'ditjaarleidstf',          $ditjaarleidstf);
        wachthond($extdebug,1, 'ditjaareventleidyes',     $ditjaareventleidyes);
        wachthond($extdebug,1, "### INT 13.X SKIPPED CREATE INTAKE ACTIVITIES REF", "[groupID: $groupID]");
        wachthond($extdebug,4, "########################################################################");
    }

    if ($extvog == 123 AND $extact == 1 AND in_array($groupID, $profilepartleidmax) AND $ditjaareventleidyes == 1) {

        $intake_array = array(
            'vog_nodig'       => $new_cont_vognodig,
            'vog_verzoek'     => $part_vogverzoek,
            'vog_aanvraag'    => $part_vogaanvraag,
            'vog_datum'       => $part_vogdatum,
        );

        wachthond($extdebug,3, "########################################################################");
        wachthond($extdebug,1, "### INT 16.3 CREATE AN ACTIVITY VOGVERZOEK VOOR $displayname", "[ALVAST ALS PLACEHOLDER]");
        wachthond($extdebug,3, "########################################################################");

        wachthond($extdebug,3, 'vogverzoek_activity_id',   $vogverzoek_activity_id);

        if (empty($vogverzoek_activity_id) AND in_array($new_cont_vognodig, array('eerstex','opnieuw','elkjaar','inhaal'))) {

            $activity_array['activity_type_id']     = 118;
            $activity_array['activity_type_naam']   = 'vog_verzoek';
            $activity_array['activity_subject']     = 'VOG aanvraag verzocht';

            $intake_activity_create = intake_activity_create($contact_id, $activity_array, $event_array, $intake_array);
            wachthond($extdebug,3, "intake_activity_create",    "[NEW ACTID: $intake_activity_create]");
            $vogverzoek_activity_id = $intake_activity_create;

        } else {
            wachthond($extdebug,2, "INFO: Er wordt GEEN activiteit VOGVERZOEK aangemaakt", "[aid: $vogverzoek_activity_id]");
        }

        wachthond($extdebug,3, "########################################################################");
        wachthond($extdebug,1, "### INT 16.4 CREATE AN ACTIVITY VOGAANVRAAG VOOR $displayname", "[ALS VOG AANVRAAG IS INGEDIEND]");
        wachthond($extdebug,3, "########################################################################");

        if (empty($vogaanvraag_activity_id) AND in_array($new_cont_vognodig, array('eerstex','opnieuw','elkjaar','inhaal'))) {
      
            $activity_array['activity_type_id']     = 119;
            $activity_array['activity_type_naam']   = 'vog_aanvraag';
            $activity_array['activity_subject']     = 'VOG aanvraag ingediend';
            
            $intake_activity_create = intake_activity_create($contact_id, $activity_array, $event_array, $intake_array);
            wachthond($extdebug,3, "intake_activity_create",    "[NEW ACTID: $intake_activity_create]");
            $vogaanvraag_activity_id = $intake_activity_create;            

        } else {
            wachthond($extdebug,2, "INFO: Er wordt GEEN activiteit VOGAANVRAAG aangemaakt", "[aid: $vogaanvraag_activity_id]");
        }

        wachthond($extdebug,3, "########################################################################");
        wachthond($extdebug,1, "### INT 16.4 CREATE AN ACTIVITY VOGONTVANGST VOOR $displayname", "[ALS VOG AANVRAAG IS INGEDIEND]");
        wachthond($extdebug,3, "########################################################################");

        if (empty($vogontvangst_activity_id) AND in_array($new_cont_vognodig, array('eerstex','opnieuw','elkjaar','inhaal'))) {

            $activity_array['activity_type_id']     = 120;
            $activity_array['activity_type_naam']   = 'vog_ontvangst';
            $activity_array['activity_subject']     = 'VOG ontvangst bevestigd';

            $intake_activity_create = intake_activity_create($contact_id, $activity_array, $event_array, $intake_array);
            wachthond($extdebug,3, "intake_activity_create",    "[NEW ACTID: $intake_activity_create]");
            $vogontvangst_activity_id = $intake_activity_create;            

        } else {
            wachthond($extdebug,2, "INFO: Er wordt GEEN activiteit VOGONTVANGST aangemaakt", "[aid: $vogontvangst_activity_id]");
        }

    } else {
        wachthond($extdebug,1, "########################################################################");
        wachthond($extdebug,1, 'extvog',                            $extvog);
        wachthond($extdebug,1, 'extact',                            $extact);
        wachthond($extdebug,1, 'ditjaarleidstf',                    $ditjaarleidstf);
        wachthond($extdebug,1, 'ditjaareventleidyes',               $ditjaareventleidyes);
        wachthond($extdebug,1, 'profilepartleidmax',                $profilepartleidmax);           
        wachthond($extdebug,1, "### INT 13.X SKIPPED CREATE INTAKE ACTIVITIES VOG", "[groupID: $groupID]");
        wachthond($extdebug,4, "########################################################################");
    }

    if ($extact == 1 AND in_array($groupID, $profilepartleidmax) AND ($ditjaareventleidyes == 1 OR $ditjaarleidstf == 1)) {

      wachthond($extdebug,1, "########################################################################");
      wachthond($extdebug,1, "### INT 17. BEPAAL NIEUWE STATUS ONDERDELEN INTAKE $displayname", "[groupID: $groupID]");
      wachthond($extdebug,1, "########################################################################");
    }

    if ($extref == 1 AND $extact == 1 AND in_array($groupID, $profilepartleidmax) AND ($ditjaareventleidyes == 1 OR $ditjaarleidstf == 1)) {

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INT 17.1 a BEPAAL NEW STATUS ACTIVITEIT REF PERSOON VOOR $displayname", "[groupID: $groupID]");
        wachthond($extdebug,2, "########################################################################");

        $new_refpersoon_actstatus   = 'Available';          // DEFAULT TO AVAILABLE (CONCEPT)
        $new_refpersoon_actprio     = 'Normaal';            // DEFAULT TO NORMAL

        $part_refpersoon_infiscalyear_ditevent = infiscalyear($part_refpersoon, $ditevent_event_start, 'refpersoon', 'ditevent')  ?? 0;

        wachthond($extdebug,3, "- new_part_refnodig",       $new_part_refnodig);
        wachthond($extdebug,3, "- new_cont_refnodig",       $new_cont_refnodig);

        wachthond($extdebug,2, "- part_refpersoon",         $part_refpersoon);
        wachthond($extdebug,2, "- part_refpersoon_infiscalyear_ditevent",   "$part_refpersoon_infiscalyear_ditevent [part_refpersoon: $part_refpersoon]");

        wachthond($extdebug,2, "1 new_part_refstatus",      $new_part_refstatus);
        wachthond($extdebug,2, "1 new_cont_refstatus",      $new_cont_refstatus);
        wachthond($extdebug,2, "1 new_refpersoon_actstatus",$new_refpersoon_actstatus);

        wachthond($extdebug,2, "part_vogverzoek",          $part_vogverzoek);
        wachthond($extdebug,2, "new_part_vogverzoek",      $new_part_vogverzoek);

        if (in_array($new_cont_refnodig, array("noggoed"))) {
            $new_refpersoon_actstatus   = 'Not Required';
        } else {
            $diffsince_refpersoon   = date_diff(date_create($part_refgevraagd),date_create($today_datetime))    ?? NULL;
            $dayssince_refpersoon   = $diffsince_refpersoon->format('%a')                                       ?? NULL;
            wachthond($extdebug,2, "- diffsince_refpersoon",  $diffsince_refpersoon);
            wachthond($extdebug,2, "- dayssince_refpersoon",  $dayssince_refpersoon);

            if ($part_refpersoon_infiscalyear_ditevent == 1) {
                $new_refpersoon_actstatus   = 'Completed';
                $new_cont_refstatus         = 'bekend';
            } elseif ($part_vogverzoek) {   // M61: zet referenties pas in werking na klaarzetten VOG
                $new_cont_refstatus         = 'ontbreekt';

                if ($dayssince_refpersoon >= 0  AND $dayssince_refpersoon < 7)      { $new_refpersoon_actstatus = "Pending";     } // AFWACHTING
                if ($dayssince_refpersoon >= 7  AND $dayssince_refpersoon < 21)     { $new_refpersoon_actstatus = "Left Message";} // HERINNERD
                if ($dayssince_refpersoon >= 21 AND $dayssince_refpersoon < 35)     { $new_refpersoon_actstatus = "Unreachable"; } // ONBEREIKBAAR
                if ($dayssince_refpersoon >= 35)                                    { $new_refpersoon_actstatus = "No_show";     } // VERLOPEN
                if ($dayssince_refpersoon >= 270)                                   { $new_refpersoon_actstatus = "Bounced";     } // GEFAALD
            // IF EVENT INMIDDELS VOORBIJ IS
            } elseif (date_bigger($today_datetime, $ditevent_event_einde)) {
                                                                                      $new_refpersoon_actstatus = "Failed";        // NA EVENT
            } else {
                                                                                      $new_refpersoon_actstatus = "Available";     // CONCEPT
            }

            if ($new_refpersoon_actstatus == "Pending")     { $new_refpersoon_actprio = 'Laag';   }   // AFWACHTING
            if ($new_refpersoon_actstatus == "Left Message"){ $new_refpersoon_actprio = 'Normaal';}   // HERINNERD
            if ($new_refpersoon_actstatus == "Unreachable") { $new_refpersoon_actprio = 'Urgent'; }   // ONBEREIKBAAR
            if ($new_refpersoon_actstatus == "No_show")     { $new_refpersoon_actprio = 'Urgent'; }   // VERLOPEN
            if ($new_refpersoon_actstatus == "Bounced")     { $new_refpersoon_actprio = 'Urgent'; }   // GEFAALD/GEBOUNCED

            wachthond($extdebug,2, "2 new_part_refstatus",              $new_part_refstatus);
            wachthond($extdebug,2, "2 new_cont_refstatus",              $new_cont_refstatus);
            wachthond($extdebug,2, "2 new_refpersoon_actstatus",        $new_refpersoon_actstatus);
            wachthond($extdebug,2, "2 new_refpersoon_actprio",          $new_refpersoon_actprio);
        }

        wachthond($extdebug,2, "refpersoon_activity_id",    $refpersoon_activity_id);
        wachthond($extdebug,2, "referentie_cid",            $referentie_cid);
        wachthond($extdebug,2, "part_refgevraagd",          $part_refgevraagd);
    }

    wachthond($extdebug,2, "########################################################################");
    wachthond($extdebug,1, "### INT 17.2 a BEPAAL NEW STATUS ACTIVITEIT REF VERZOEK VOOR $displayname", "[groupID: $groupID]");
    wachthond($extdebug,2, "########################################################################");

    $new_refverzoek_actstatus = 'Available';  // DEFAULT TO AVAILABLE (CONCEPT)
    $new_refverzoek_actprio   = 'Normaal';    // DEFAULT TO NORMAL
    $part_refgevraagd_infiscalyear_ditevent = infiscalyear($part_refgevraagd, $ditevent_event_start, 'refverzoek', 'ditevent')  ?? 0;

    wachthond($extdebug,3, "- new_part_refnodig",           $new_part_refnodig);
    wachthond($extdebug,3, "- new_cont_refnodig",           $new_cont_refnodig);

    wachthond($extdebug,2, "- part_refgevraagd",            $part_refgevraagd);
    wachthond($extdebug,2, "- part_refgevraagd_infiscalyear_ditevent", "$part_refgevraagd_infiscalyear_ditevent [part_refgevraagd: $part_refgevraagd]");

    wachthond($extdebug,2, "1 new_part_refstatus",          $new_part_refstatus);    
    wachthond($extdebug,2, "1 new_cont_refstatus",          $new_cont_refstatus);
    wachthond($extdebug,2, "1 new_refverzoek_actstatus",    $new_refverzoek_actstatus);

    if (in_array($new_cont_refnodig, array("noggoed"))) {
        $new_refverzoek_actstatus   = 'Not Required';
    } else {
        $diffsince_refverzoek   = date_diff(date_create($part_refgevraagd),date_create($today_datetime))    ?? NULL;
        $dayssince_refverzoek   = $diffsince_refverzoek->format('%a')                                       ?? NULL;
        wachthond($extdebug,2, "- diffsince_refverzoek",  $diffsince_refverzoek);
        wachthond($extdebug,2, "- dayssince_refverzoek",  $dayssince_refverzoek);

        if ($part_reffeedback OR $referentie_feedback) {
            $new_refpersoon_actstatus   = 'Completed';
            $new_refverzoek_actstatus   = 'Completed';
            $new_cont_refstatus         = 'ontvangen';
        } elseif ($part_refgevraagd) {
            $new_refpersoon_actstatus   = 'Completed';
            $new_refverzoek_actstatus   = 'Completed';
            $new_cont_refstatus         = 'afwachting';

            if ($dayssince_refverzoek >  0  AND $dayssince_refverzoek < 7)      { $new_refverzoek_actstatus = "Pending";        } // AFWACHTING
            if ($dayssince_refverzoek >= 7  AND $dayssince_refverzoek < 21)     { $new_refverzoek_actstatus = "Left Message";   } // HERINNERD
            if ($dayssince_refverzoek >= 21 AND $dayssince_refverzoek < 35)     { $new_refverzoek_actstatus = "Unreachable";    } // ONBEREIKBAAR
            if ($dayssince_refverzoek >= 35)                                    { $new_refverzoek_actstatus = "No_show";        } // VERLOPEN
            if ($dayssince_refverzoek >= 270)                                   { $new_refverzoek_actstatus = "Bounced";        } // GEFAALD
        // IF EVENT INMIDDELS VOORBIJ IS
        } elseif (date_bigger($today_datetime, $ditevent_event_einde)) {
                                                                                  $new_refverzoek_actstatus = "Failed";           // NA EVENT
        } else {
                                                                                  $new_refverzoek_actstatus = "Scheduled";        // INGEPLAND
        }

        if ($new_refverzoek_actstatus == "Pending")     { $new_refverzoek_actprio = 'Laag';   }   // AFWACHTING
        if ($new_refverzoek_actstatus == "Left Message"){ $new_refverzoek_actprio = 'Normaal';}   // HERINNERD
        if ($new_refverzoek_actstatus == "Unreachable") { $new_refverzoek_actprio = 'Urgent'; }   // ONBEREIKBAAR
        if ($new_refverzoek_actstatus == "No_show")     { $new_refverzoek_actprio = 'Urgent'; }   // VERLOPEN
        if ($new_refverzoek_actstatus == "Bounced")     { $new_refverzoek_actprio = 'Urgent'; }   // GEFAALD/GEBOUNCED

        wachthond($extdebug,2, "2 new_part_refstatus",              $new_part_refstatus);
        wachthond($extdebug,2, "2 new_cont_refstatus",              $new_cont_refstatus);
        wachthond($extdebug,2, "2 new_refverzoek_actstatus",        $new_refverzoek_actstatus);
        wachthond($extdebug,2, "2 new_refverzoek_actprio",          $new_refverzoek_actprio);
    }

    if ($extvog == 123 AND $extact == 1 AND ($diteventleidyes == 1 OR $diteventleidstf == 1)) {

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INT 17.3 a BEPAAL NEW STATUS ACTIVITEIT VOG VERZOEK VOOR $displayname", "[groupID: $groupID]");
        wachthond($extdebug,2, "########################################################################");

        $new_vogverzoek_actstatus     = 'Pending';      // DEFAULT TO AVAILABLE (AFWACHTING)
        $new_vogverzoek_actprio       = 'Normaal';      // DEFAULT TO NORMAL
        $vogverzoek_infiscalyear_ditevent   = infiscalyear($part_vogverzoek,$ditevent_event_start, 'vogverzoek', 'ditevent') ?? 0;
        $vogdatum_infiscalyear_ditevent     = infiscalyear($part_vogdatum,  $ditevent_event_start, 'vogdatum',   'ditevent') ?? 0;

        wachthond($extdebug,3, "- vogdatum_infiscalyear_ditevent",  "$vogdatum_infiscalyear_ditevent [vogdatum: $part_vogdatum]");
        wachthond($extdebug,2, "- part_vogverzoek",                     $part_vogverzoek);
        wachthond($extdebug,3, "- vogverzoek_infiscalyear_ditevent",   "$vogverzoek_infiscalyear_ditevent [part_vogverzoek: $part_vogverzoek]");

        wachthond($extdebug,2, "1 new_part_vognodig",               $new_part_vognodig);
        wachthond($extdebug,2, "1 new_part_vogstatus",              $new_part_vogstatus);
        wachthond($extdebug,2, "1 new_vogverzoek_actstatus",        $new_vogverzoek_actstatus);
        wachthond($extdebug,2, "1 new_vogverzoek_actprio",          $new_vogverzoek_actprio);

        if (in_array($new_part_vognodig, array("noggoed"))) {
            $new_part_vogstatus             = 'noggoed';
            $new_vogaanvraag_actstatus      = 'Not Required';
        } elseif ($vogverzoek_infiscalyear_ditevent == 1) {
            $new_part_vogstatus             = 'verzocht';
            $new_vogverzoek_actstatus       = 'Completed';
        } elseif (empty($part_vogverzoek)) {
            $new_part_vogstatus             = 'klaarzetten';
            $new_vogverzoek_actstatus       = 'Pending';
        } elseif (date_bigger($today_datetime, $ditevent_event_einde)) {
            $new_part_vogstatus             = 'verlopen';
            $new_vogverzoek_actstatus       = 'Bounced';            
        } else {
            $new_refverzoek_actstatus       = "Scheduled";          // INGEPLAND
        }

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INT 17.3 b COPY VOGSTATUS DITEVENT > DITJAAR INDIEN EVENT DITJAAR $displayname", "[groupID: $groupID]");
        wachthond($extdebug,2, "########################################################################");

        if ($diteventleidyes == 1 OR $diteventleidstf == 1) {

            wachthond($extdebug,2, "2 new_part_vognodig",           $new_part_vognodig);
            wachthond($extdebug,2, "2 new_part_vogstatus",          $new_part_vogstatus);
            wachthond($extdebug,2, "2 new_vogverzoek_actstatus",    $new_vogverzoek_actstatus);
            wachthond($extdebug,2, "2 new_vogverzoek_actprio",      $new_vogverzoek_actprio);
        }

        if ($ditjaareventleidyes == 1 OR $ditjaareventleidstf == 1) {

            wachthond($extdebug,2,  "VOGSTATUS ($new_cont_vogstatus) UIT DITEVENT GEKOPIEERD NAAR DITJAAR", "[WANT EVENT IS IN DITJAAR]");

            // M61: KLOPT NIET HIERONDER

            $new_cont_vogstatus                 = $new_part_vogstatus;
            $new_vogverzoek_actstatus           = $new_vogverzoek_actstatus;
            $new_vogverzoek_actprio             = $new_vogverzoek_actprio;

            wachthond($extdebug,2, "2 new_cont_vognodig",           $new_cont_vognodig);
            wachthond($extdebug,2, "2 new_cont_vogstatus",          $new_cont_vogstatus);
            wachthond($extdebug,2, "2 new_vogverzoek_actstatus",    $new_vogverzoek_actstatus);
            wachthond($extdebug,2, "2 new_vogverzoek_actprio",      $new_vogverzoek_actprio);

        } else {

            wachthond($extdebug,2, 'ditjaareventleidyes',   $ditjaareventleidyes);
            wachthond($extdebug,2, 'ditjaareventleidstf',   $ditjaareventleidstf);

            wachthond($extdebug,2, "########################################################################");
            wachthond($extdebug,2,  "VOGSTATUS UIT DITEVENT NIET KOPIEREN NAAR DITJAAR WANT EVENT =! DITJAAR");
            wachthond($extdebug,2, "########################################################################");
        }

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INT 17.4 a BEPAAL NEW STATUS ACTIVITEIT VOG AANVRAAG VOOR $displayname", "[groupID: $groupID]");
        wachthond($extdebug,2, "########################################################################");

        $intake_status_vogaanvraag_array  = intake_status_vogaanvraag($contact_id, $array_allpart_ditjaar, $event_array, $intake_array, $groupID);
        wachthond($extdebug,2, "intake_status_vogaanvraag_array",   $intake_status_vogaanvraag_array);

        $new_cont_vogstatus         = $intake_status_vogaanvraag_array['new_cont_vogstatus'];
        $new_part_vogstatus         = $intake_status_vogaanvraag_array['new_part_vogstatus'];
        $new_vogaanvraag_actdatum   = $intake_status_vogaanvraag_array['new_vogaanvraag_actdatum'];
        $new_vogaanvraag_actstatus  = $intake_status_vogaanvraag_array['new_vogaanvraag_actstatus'];
        $new_vogaanvraag_actprio    = $intake_status_vogaanvraag_array['new_vogaanvraag_actprio'];

        wachthond($extdebug,2, "new_cont_vogstatus",        $new_cont_vogstatus);
        wachthond($extdebug,2, "new_part_vogstatus",        $new_part_vogstatus);
        wachthond($extdebug,2, "new_vogaanvraag_actstatus", $new_vogaanvraag_actstatus);
        wachthond($extdebug,2, "new_vogaanvraag_actprio",   $new_vogaanvraag_actprio);

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INT 17.5 a BEPAAL NEW STATUS ACTIVITEIT VOG ONTVANGST VOOR $displayname", "[groupID: $groupID]");
        wachthond($extdebug,2, "########################################################################");

        $intake_status_vogontvangst_array  = intake_status_vogontvangst($contact_id, $array_allpart_ditjaar, $event_array, $intake_array, $groupID);
        wachthond($extdebug,2, "intake_status_vogontvangst_array",   $intake_status_vogontvangst_array);

        $new_cont_vogstatus         = $intake_status_vogontvangst_array['new_cont_vogstatus'];
        $new_part_vogstatus         = $intake_status_vogontvangst_array['new_part_vogstatus'];
        $new_vogontvangst_actdatum  = $intake_status_vogontvangst_array['new_vogontvangst_actdatum'];        
        $new_vogontvangst_actstatus = $intake_status_vogontvangst_array['new_vogontvangst_actstatus'];
        $new_vogontvangst_actprio   = $intake_status_vogontvangst_array['new_vogontvangst_actprio'];

        wachthond($extdebug,2, "new_cont_vogstatus",        $new_cont_vogstatus);
        wachthond($extdebug,2, "new_part_vogstatus",        $new_part_vogstatus);
        wachthond($extdebug,2, "new_vogontvangst_actstatus",$new_vogontvangst_actstatus);
        wachthond($extdebug,2, "new_vogontvangst_actprio",  $new_vogontvangst_actprio);
/*
        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INT 17.5 a BEPAAL NEW STATUS ACTIVITEIT VOG ONTVANGST VOOR $displayname", "[groupID: $groupID]");
        wachthond($extdebug,2, "########################################################################");

        $new_vogontvangst_actstatus = 'Available';  // DEFAULT TO AVAILABLE (CONCEPT)
        $new_vogontvangst_actprio   = 'Normaal';    // DEFAULT TO NORMAL

        $vogdatum_infiscalyear_ditevent     = infiscalyear($part_vogdatum,      $ditevent_event_start, 'vogdatum',      'ditevent') ?? 0;

        wachthond($extdebug,4, "1 ditevent_part_vogdatum",          $ditevent_part_vogdatum);
        wachthond($extdebug,4, "1 part_vogdatum",                   $part_vogdatum);
        wachthond($extdebug,3, "- vogdatum_infiscalyear_ditevent", "$vogdatum_infiscalyear_ditevent\t[part_vogdatum: $part_vogdatum]");

