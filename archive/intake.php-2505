        wachthond($extdebug,2, "0 new_vogontvangst_actstatus",      $new_vogontvangst_actstatus);
        wachthond($extdebug,2, "0 new_vogontvangst_actprio",        $new_vogontvangst_actprio);

    if (in_array($new_cont_vognodig, array("noggoed"))) {
        $new_vogontvangst_actstatus   = 'Not Required';
    } else {
        $diffsince_vogaanvraag  = date_diff(date_create($part_vogaanvraag),date_create($today_datetime))   ?? NULL;
        $dayssince_vogaanvraag  = $diffsince_vogaanvraag->format('%a')                                      ?? NULL;
