        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE [PRE] 3.1 NAW - EERSTEX DAN NAWDATE = REGDATE",        "[NAW]");
        wachthond($extdebug,2, "########################################################################");

        $new_cont_nawgecheckt   = $val_naw_gecheckt;

        if ($curcv_keer_leid == 1) {
            $new_cont_nawgecheckt   = $ditevent_register_date;
        }
        wachthond($extdebug,3,  "new_cont_nawgecheckt", $new_cont_nawgecheckt);

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE [PRE] 3.2 NAW - BEPAAL STATUS",                        "[NAW]");
        wachthond($extdebug,2, "########################################################################");

        $nawgecheckt_infiscalyear_ditjaar   = infiscalyear($val_naw_gecheckt, $today_datetime, 'nawgecheckt','ditjaar');

        if ($nawgecheckt_infiscalyear_ditjaar == 1) {
            $new_cont_nawstatus     = 'bijgewerkt';
            wachthond($extdebug,1,  "NAW GECHECKT [$krt_naw_gecheckt] > FISCALE JAAR [>$today_fiscalyear_start]", 
                                    "[$new_cont_nawstatus]");
        } else {
            $new_cont_nawstatus     = 'ongecheckt';
        }

        if ($nawgecheckt_infiscalyear_ditjaar == 'before') {
            $new_cont_nawstatus     = 'ongecheckt';
            wachthond($extdebug,1,  "NAW GECHECKT [$krt_naw_gecheckt] < FISCALE JAAR [<$today_fiscalyear_start]",
                                    "[$new_cont_nawstatus]");
        }

        if ($curcv_keer_leid == 1) {
            $new_cont_nawstatus     = 'bijgewerkt';
        }

        wachthond($extdebug,4,  "new_cont_nawstatus",       $new_cont_nawstatus);

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE [PRE] 3.3 NAW - INJECTEER WAARDE IN PARAMS",           "[NAW]");
        wachthond($extdebug,2, "########################################################################");

        wachthond($extdebug,4,  "key_naw_gecheckt",         $key_naw_gecheckt);

        // M61 converteer de datum naar een manier die weg te schrijven is in params
        $new_cont_nawgecheckt_datetime  = new DateTime($new_cont_nawgecheckt);
        wachthond($extdebug,3, 'new_cont_nawgecheckt_datetime',   $new_cont_nawgecheckt_datetime);
        $new_cont_nawgecheckt_string    = $new_cont_nawgecheckt_datetime->format('Y-m-d H:i:s');
        wachthond($extdebug,3, 'new_cont_nawgecheckt_string',     $new_cont_nawgecheckt_string);
        $new_cont_nawgecheckt_dbstring  = date("YmdHis", strtotime($new_cont_nawgecheckt_string));
        wachthond($extdebug,2, 'new_cont_nawgecheckt_dbstring',   $new_cont_nawgecheckt_dbstring);

        if (is_numeric($key_naw_gecheckt) AND !empty($new_cont_nawgecheckt)) {
            wachthond($extdebug,3, 'OLD params[key_naw_gecheckt][value]', $params[$key_naw_gecheckt]);
            $params[$key_naw_gecheckt]['value'] = $new_cont_nawgecheckt_dbstring;
            wachthond($extdebug,3, 'NEW params[key_naw_gecheckt][value]', $params[$key_naw_gecheckt]);
        }

        wachthond($extdebug,4,  "key_naw_status",           $key_naw_status);

        if (is_numeric($key_naw_status) AND !empty($new_cont_nawstatus)) {
            wachthond($extdebug,3, 'OLD params[key_naw_status][value]', $params[$key_naw_status]);
            $params[$key_naw_status]['value'] = $new_cont_nawstatus;
            wachthond($extdebug,3, 'NEW params[key_naw_status][value]', $params[$key_naw_status]);
        }

        wachthond($extdebug,4, 'new_cont_nawnodig',         $new_cont_nawnodig);
        wachthond($extdebug,1, 'new_cont_nawgecheckt',      $new_cont_nawgecheckt);
        wachthond($extdebug,3, 'new_cont_nawstatus',        $new_cont_nawstatus);

        wachthond($extdebug,2, "########################################################################");
        wachthond($extdebug,1, "### INTAKE [PRE] 4.1 PAS BIO GECHECKT AAN OBV BIO INGEVULD");
        wachthond($extdebug,2, "########################################################################");

        // WHEN BIO INGEVULD IS AANWEZIG EN NIEUWER DAN BIO GECHECKT

        if (date_biggerequal($val_bio_ingevuld, $val_bio_gecheckt, 'bioingevuld', 'biogecheckt') == 1) {

            wachthond($extdebug,2, 'org_bio_ingevuld',          $val_bio_ingevuld);
            wachthond($extdebug,2, 'val_bio_gecheckt',          $val_bio_gecheckt);

            $val_bio_gecheckt       = $val_bio_ingevuld;        // M61 overschrijf de waarde voor gebruik in 2.3
            $krt_bio_gecheckt       = $krt_bio_ingevuld;        // M61 overschrijf de waarde voor gebruik in 2.3
            $new_cont_biogecheckt   = $new_cont_bioingevuld; 

            if ($key_bio_gecheckt AND !empty($val_bio_ingevuld)) {

                wachthond($extdebug,3, 'OLD params[key_bio_gecheckt]',  $params[$key_bio_gecheckt]);                    
                $params[$key_bio_gecheckt]['value'] =                   $params[$key_bio_ingevuld]['value'];
                wachthond($extdebug,3, 'NEW params[key_bio_gecheckt]',  $params[$key_bio_gecheckt]);
            }

            wachthond($extdebug,1,  "OVERSCHRIJF BIO GECHECKT [$val_bio_gecheckt] MET RECENTERE DATUM BIO INGEVULD [$val_bio_ingevuld]");
        }

        // WHEN BIO INGEVULD IS AANWEZIG MAAR BIO GECHECKT = LEEG

        if ($val_bio_ingevuld AND empty($val_bio_gecheckt)) {

            wachthond($extdebug,2, 'org_bio_ingevuld',          $val_bio_ingevuld);
            wachthond($extdebug,2, 'val_bio_gecheckt',          $val_bio_gecheckt);

            $val_bio_gecheckt       = $val_bio_ingevuld;        // M61 overschrijf de waarde voor gebruik in 2.3
            $krt_bio_gecheckt       = $krt_bio_ingevuld;        // M61 overschrijf de waarde voor gebruik in 2.3
            $new_cont_biogecheckt   = $new_cont_bioingevuld; 

            if ($key_bio_gecheckt AND !empty($val_bio_ingevuld)) {

                wachthond($extdebug,3, 'OLD params[key_bio_gecheckt]',  $params[$key_bio_gecheckt]);                    
                $params[$key_bio_gecheckt]['value'] =                   $params[$key_bio_ingevuld]['value'];
                wachthond($extdebug,3, 'NEW params[key_bio_gecheckt]',  $params[$key_bio_gecheckt]);
