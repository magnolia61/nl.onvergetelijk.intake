        }

        $grensvognoggoed1       = Civi::cache()->get('cache_grensvognoggoed1')          ?? NULL;
        $grensvognoggoed3       = Civi::cache()->get('cache_grensvognoggoed3')          ?? NULL;
        $grensrefnoggoed3       = Civi::cache()->get('cache_grensrefnoggoed3')          ?? NULL;
