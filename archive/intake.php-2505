        wachthond($extdebug,3, 'grensnoggoedjaar',          $grensnoggoedjaar);

        wachthond($extdebug,1, "########################################################################");
        wachthond($extdebug,1, "### INT 10.6 CHECK STATUS DITEVENT & DITJAAR MEE", "[groupID: $groupID]");
        wachthond($extdebug,1, "########################################################################");

