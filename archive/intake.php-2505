        wachthond($extdebug,2, 'ditevent_leid_welkkamp',    $ditevent_leid_welkkamp);

        if ($ditevent_event_type_id == 1 AND $ditevent_leid_welkkamp) {
            $diteventleidyes        = 1;
        }

