                    'ref_aanvrager.referentie_naam'         => $referentie_name,
                    'ref_aanvrager.referentie_relatie'      => $referentie_relatie,
                    'ref_aanvrager.referentie_motivatie'    => $referentie_motivatie,
                    'ref_aanvrager.referentie_toestemming'  => $referentie_toestemming,
                    'ref_aanvrager.referentie_verzoek'      => $referentie_gevraagd,
                    'ref_feedback.datum_feedback'           => $referentie_feedback,
                    'ref_feedback.referentie_naam'          => $referentie_name,
                    'ref_feedback.referentie_telefoon'      => $referentie_phone,
                ],
            ];

            if ($ditevent_fiscalyear_start)     { $params_ref_update['values']['start_date']                = $ditevent_fiscalyear_start;   }
            if ($ditevent_fiscalyear_einde)     { $params_ref_update['values']['end_date']                  = $ditevent_fiscalyear_einde;   }

            if ($ref_fiscalyear_start)          { $params_ref_update['values']['start_date']                = $ref_fiscalyear_start;        }
            if ($ref_fiscalyear_einde)          { $params_ref_update['values']['end_date']                  = $ref_fiscalyear_einde;        }

