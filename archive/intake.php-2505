            if ($dayssince_vogaanvraag >= 14 AND $dayssince_vogaanvraag < 28)   { $new_vogontvangst_actstatus = "Left Message"; } // HERINNERD
            if ($dayssince_vogaanvraag >= 28)                                   { $new_vogontvangst_actstatus = "Unreachable";  } // ONBEREIKBAAR
            if ($dayssince_vogaanvraag >= 270)                                  { $new_vogontvangst_actstatus = "Bounced";      } // GEFAALD
        // IF EVENT INMIDDELS VOORBIJ IS
        } elseif (date_bigger($today_datetime, $ditevent_event_einde)) {
                                                                                  $new_vogontvangst_actstatus = "Failed";         // NA EVENT
        } else {
                                                                                  $new_vogontvangst_actstatus = "Scheduled";      // CONCEPT
        }

        if ($new_vogontvangst_actstatus == "Pending")       { $new_vogontvangst_actprio = 'Laag';   }   // AFWACHTING
        if ($new_vogontvangst_actstatus == "Left Message")  { $new_vogontvangst_actprio = 'Normaal';}   // HERINNERD
