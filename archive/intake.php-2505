            'ditevent_part_kampjaar'    => $ditevent_kampjaar,

            'ditevent_part_kampjaar'    => $ditevent_kampjaar,
            'ditevent_part_kampstart'   => $ditevent_part_kampstart,
            'ditevent_part_kampeinde'   => $ditevent_part_kampeinde,
            'ditevent_event_kampstart'  => $ditevent_event_start,
